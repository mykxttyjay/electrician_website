---
// Services component for electrician website
import Button from './Button.astro';
---

<section class="bg-[#F8F8F8] py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="mb-12">
      <p class="text-[#F4C430] font-semibold mb-2" style="font-size: 18px;">Our Services</p>
      <h2 class="heading-h2 font-bold text-black mb-4" style="line-height: 1.2;">Professional Electrical<br><span class="whitespace-nowrap">Solutions You Need</span></h2>
      <p class="text-gray-700 leading-relaxed max-w-3xl" style="font-size: 22px;">
        Professional electrical solutions tailored to meet your residential and commercial needs with safety, efficiency, and reliability guaranteed.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Service 1: Residential Wiring -->
      <div class="bg-white rounded-lg overflow-hidden group hover:shadow-xl transition-all">
        <div class="h-2 bg-[#F4C430]"></div>
        <div class="p-6 relative">
          <div class="absolute top-6 right-6 text-[200px] font-bold text-gray-100 leading-none">1</div>
          <div class="relative z-10 mb-4">
            <svg class="w-16 h-16 text-[#F4C430]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-black mb-3">Residential Wiring</h3>
          <p class="text-gray-600 mb-6" style="font-size: 14px;">
            Complete home electrical installations, rewiring, and upgrades to ensure safety and meet modern power demands.
          </p>
          <a href="/services/residential" class="text-black font-semibold flex items-center gap-2 hover:text-[#F4C430] transition-colors">
            Read More
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Service 2: Commercial Electrical -->
      <div class="bg-white rounded-lg overflow-hidden group hover:shadow-xl transition-all">
        <div class="h-2 bg-[#F4C430]"></div>
        <div class="p-6 relative">
          <div class="absolute top-6 right-6 text-[200px] font-bold text-gray-100 leading-none">2</div>
          <div class="relative z-10 mb-4">
            <svg class="w-16 h-16 text-[#F4C430]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-black mb-3">Commercial Electrical</h3>
          <p class="text-gray-600 mb-6" style="font-size: 14px;">
            Professional electrical services for offices, retail spaces, and industrial facilities with minimal downtime.
          </p>
          <a href="/services/commercial" class="text-black font-semibold flex items-center gap-2 hover:text-[#F4C430] transition-colors">
            Read More
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Service 3: Panel Upgrades -->
      <div class="bg-white rounded-lg overflow-hidden group hover:shadow-xl transition-all">
        <div class="h-2 bg-[#F4C430]"></div>
        <div class="p-6 relative">
          <div class="absolute top-6 right-6 text-[200px] font-bold text-gray-100 leading-none">3</div>
          <div class="relative z-10 mb-4">
            <svg class="w-16 h-16 text-[#F4C430]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-black mb-3">Panel Upgrades</h3>
          <p class="text-gray-600 mb-6" style="font-size: 14px;">
            Modernize your electrical panel to handle increased power loads and improve overall system safety and efficiency.
          </p>
          <a href="/services/panel-upgrades" class="text-black font-semibold flex items-center gap-2 hover:text-[#F4C430] transition-colors">
            Read More
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Service 4: Emergency Repairs -->
      <div class="bg-white rounded-lg overflow-hidden group hover:shadow-xl transition-all">
        <div class="h-2 bg-[#F4C430]"></div>
        <div class="p-6 relative">
          <div class="absolute top-6 right-6 text-[200px] font-bold text-gray-100 leading-none">4</div>
          <div class="relative z-10 mb-4">
            <svg class="w-16 h-16 text-[#F4C430]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-black mb-3">Emergency Repairs</h3>
          <p class="text-gray-600 mb-6" style="font-size: 14px;">
            24/7 emergency electrical services to quickly resolve urgent issues and restore power safely to your property.
          </p>
          <a href="/services/emergency" class="text-black font-semibold flex items-center gap-2 hover:text-[#F4C430] transition-colors">
            Read More
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
