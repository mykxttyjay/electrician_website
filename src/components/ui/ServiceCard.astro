---
interface Props {
  name: string;
  image: string;
}

const { name, image } = Astro.props;
---

<div class="group cursor-pointer relative overflow-hidden rounded-lg">
  <div class="w-full aspect-square overflow-hidden bg-gray-200 rounded-lg">
    <img 
      src={image} 
      alt={name}
      class="w-full h-full object-cover"
      loading="lazy"
      decoding="async"
    />
  </div>
  <!-- Hover Overlay -->
  <div class="absolute inset-0 bg-gradient-to-r from-[#F4C430]/90 to-[#F4C430]/70 translate-x-[-100%] group-hover:translate-x-0 transition-transform duration-500 ease-in-out flex items-end justify-center pb-6">
    <h4 class="font-black text-black text-center px-4 text-lg drop-shadow-lg">{name}</h4>
  </div>
</div>
