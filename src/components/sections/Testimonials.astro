---
// Import all testimonial markdown files
const testimonialFiles = import.meta.glob('../content/testimonials/testimonial-*.md', { eager: true });
const testimonials = Object.values(testimonialFiles).map((file: any) => {

  const rawContent = file.rawContent ? file.rawContent() : '';
  const cleanText = rawContent.replace(/^---[\s\S]*?---\n/, '').trim(); 
  
  return {
    name: file.frontmatter.name,
    role: file.frontmatter.role,
    image: file.frontmatter.image,
    text: cleanText
  };
});
