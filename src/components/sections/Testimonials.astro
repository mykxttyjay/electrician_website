---
const testimonials = [
  {
    name: "Michael Rodriguez",
    role: "Homeowner",
    image: "https://images.unsplash.com/photo-1560250097-0b93528c311a?w=100&h=100&fit=crop",
    text: "Excellent service from start to finish. The team was professional, punctual, and completed our home rewiring project ahead of schedule. They took the time to explain everything clearly and ensured all work met code requirements. The quality of their craftsmanship is outstanding, and I highly recommend their expertise and attention to detail to anyone needing electrical work."
  },
  {
    name: "Sarah Johnson",
    role: "Business Owner",
    image: "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=100&h=100&fit=crop",
    text: "Outstanding electrical work for our commercial space. They handled everything efficiently with minimal disruption to our business operations. The team was incredibly respectful of our schedule and worked around our busy hours. The quality of work exceeded our expectations, and they even provided helpful suggestions for energy efficiency improvements. We couldn't be happier with the results."
  },
  {
    name: "David Chen",
    role: "Property Manager",
    image: "https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?w=100&h=100&fit=crop",
    text: "Reliable and trustworthy electricians who truly understand property management needs. They've handled multiple panel upgrades across our properties with consistent quality and professionalism. Their emergency response time is impressive, and they always arrive prepared with the right equipment. The pricing is fair and transparent, with no hidden fees. I trust them completely with all our electrical needs."
  },
  {
    name: "Emily Martinez",
    role: "Restaurant Owner",
    image: "https://images.unsplash.com/photo-1580489944761-15a19d654956?w=100&h=100&fit=crop",
    text: "Professional team that understands commercial needs and the unique challenges of restaurant operations. They upgraded our restaurant's electrical system efficiently and ensured everything met strict code requirements for commercial kitchens. Excellent communication throughout the project kept us informed every step of the way. They worked during our off-hours to minimize impact on our business. Highly recommended for any commercial electrical work."
  }
];
---

<section class="bg-[#F8F8F8] py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="mb-8 text-center">
      <p class="text-[#F4C430] font-semibold text-lg">Testimonials</p>
      <h2 class="heading-h2 font-bold text-black mb-3">What Our Clients Say</h2>
      <p class="text-gray-700 leading-relaxed max-w-3xl mx-auto text-subtitle">
        Hear from our satisfied customers about their experience with our professional electrical services and dedicated team.
      </p>
    </div>

    <!-- Carousel Container -->
    <div class="relative">
      <div class="testimonial-carousel overflow-hidden">
        <div class="testimonial-track flex transition-transform duration-500 ease-in-out">
          {testimonials.map((testimonial, index) => (
          <div class="testimonial-slide min-w-full md:min-w-[50%] px-3">
            <div class="bg-white border-2 border-gray-300 shadow-md p-8 h-full">
              <div class="flex items-start justify-between mb-4">
                <div class="flex items-center gap-4">
                  <img 
                    src={testimonial.image}
                    alt={testimonial.name}
                    class="w-16 h-16 rounded-full object-cover"
                  />
                  <div>
                    <h3 class="text-xl font-bold text-black">{testimonial.name}</h3>
                    <p class="text-[#F4C430] font-semibold">{testimonial.role}</p>
                  </div>
                </div>
                <svg class="w-24 h-24 text-[#F4C430] opacity-30" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/>
                </svg>
              </div>
              <p class="text-gray-700 leading-relaxed text-base">
                {testimonial.text}
              </p>
            </div>
          </div>
          ))}
          <!-- Duplicate slides for infinite loop -->
          {testimonials.map((testimonial, index) => (
          <div class="testimonial-slide min-w-full md:min-w-[50%] px-3">
            <div class="bg-white border-2 border-gray-300 shadow-md p-8 h-full">
              <div class="flex items-start justify-between mb-4">
                <div class="flex items-center gap-4">
                  <img 
                    src={testimonial.image}
                    alt={testimonial.name}
                    class="w-16 h-16 rounded-full object-cover"
                  />
                  <div>
                    <h3 class="text-xl font-bold text-black">{testimonial.name}</h3>
                    <p class="text-[#F4C430] font-semibold">{testimonial.role}</p>
                  </div>
                </div>
                <svg class="w-24 h-24 text-[#F4C430] opacity-30" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/>
                </svg>
              </div>
              <p class="text-gray-700 leading-relaxed text-base">
                {testimonial.text}
              </p>
            </div>
          </div>
          ))}
        </div>
      </div>

      <!-- Dots Navigation -->
      <div class="flex justify-center gap-2 mt-8">
        {testimonials.map((_, index) => (
        <button 
          class={`carousel-dot w-3 h-3 rounded-full transition-all ${index === 0 ? 'bg-[#F4C430]' : 'bg-gray-300'}`}
          data-index={index}
        ></button>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  let currentIndex = 0;
  const track = document.querySelector('.testimonial-track') as HTMLElement;
  const slides = document.querySelectorAll('.testimonial-slide');
  const dots = document.querySelectorAll('.carousel-dot');
  
  // Determine slides per view based on screen size
  function getSlidesPerView() {
    return window.innerWidth >= 768 ? 2 : 1;
  }
  
  const totalSlides = slides.length / 2; // Actual number of unique slides
  
  function updateCarousel(smooth = true) {
    const slidesPerView = getSlidesPerView();
    const offset = -(currentIndex * (100 / slidesPerView));
    
    if (smooth) {
      track.style.transition = 'transform 500ms ease-in-out';
    } else {
      track.style.transition = 'none';
    }
    
    track.style.transform = `translateX(${offset}%)`;
    
    // Update dots
    const dotIndex = currentIndex % totalSlides;
    dots.forEach((dot, index) => {
      if (index === dotIndex) {
        dot.classList.remove('bg-gray-300');
        dot.classList.add('bg-[#F4C430]');
      } else {
        dot.classList.remove('bg-[#F4C430]');
        dot.classList.add('bg-gray-300');
      }
    });
  }
  
  function nextSlide() {
    currentIndex++;
    updateCarousel(true);
    
    // Reset to beginning when reaching duplicates
    if (currentIndex >= totalSlides) {
      setTimeout(() => {
        currentIndex = 0;
        updateCarousel(false);
      }, 500);
    }
  }
  
  // Dot navigation
  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      currentIndex = index;
      updateCarousel(true);
    });
  });
  
  // Auto-play carousel
  let autoplayInterval = setInterval(nextSlide, 5000);
  
  // Pause on hover
  const carousel = document.querySelector('.testimonial-carousel');
  carousel?.addEventListener('mouseenter', () => {
    clearInterval(autoplayInterval);
  });
  
  carousel?.addEventListener('mouseleave', () => {
    autoplayInterval = setInterval(nextSlide, 5000);
  });
  
  // Handle window resize
  window.addEventListener('resize', () => updateCarousel(true));
  
  // Initial update
  updateCarousel(false);
</script>
