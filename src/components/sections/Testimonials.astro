---
// Testimonials component for electrician website
---

<section class="bg-[#F8F8F8] py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="mb-12 text-center">
      <p class="text-[#F4C430] font-semibold mb-2" style="font-size: 18px;">Testimonials</p>
      <h2 class="heading-h2 font-bold text-black mb-4">What Our Clients Say</h2>
    </div>

    <!-- Carousel Container -->
    <div class="relative">
      <div class="testimonial-carousel overflow-hidden">
        <div class="testimonial-track flex transition-transform duration-500 ease-in-out">
          <!-- Testimonial 1 -->
          <div class="testimonial-slide min-w-full md:min-w-[50%] px-3">
            <div class="bg-white border-2 border-gray-200 rounded-lg p-8 h-full">
              <div class="flex items-start justify-between mb-6">
                <div class="flex items-center gap-4">
                  <img 
                    src="https://images.unsplash.com/photo-1560250097-0b93528c311a?w=100&h=100&fit=crop" 
                    alt="Michael Rodriguez" 
                    class="w-16 h-16 rounded-full object-cover"
                  />
                  <div>
                    <h3 class="text-xl font-bold text-black">Michael Rodriguez</h3>
                    <p class="text-[#F4C430] font-semibold">Homeowner</p>
                  </div>
                </div>
                <svg class="w-16 h-16 text-[#FFF9E6]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/>
                </svg>
              </div>
              <p class="text-gray-700 leading-relaxed" style="font-size: 16px;">
                Excellent service from start to finish. The team was professional, punctual, and completed our home rewiring project ahead of schedule. Highly recommend their expertise and attention to detail.
              </p>
            </div>
          </div>

          <!-- Testimonial 2 -->
          <div class="testimonial-slide min-w-full md:min-w-[50%] px-3">
            <div class="bg-white border-2 border-gray-200 rounded-lg p-8 h-full">
              <div class="flex items-start justify-between mb-6">
                <div class="flex items-center gap-4">
                  <img 
                    src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=100&h=100&fit=crop" 
                    alt="Sarah Johnson" 
                    class="w-16 h-16 rounded-full object-cover"
                  />
                  <div>
                    <h3 class="text-xl font-bold text-black">Sarah Johnson</h3>
                    <p class="text-[#F4C430] font-semibold">Business Owner</p>
                  </div>
                </div>
                <svg class="w-16 h-16 text-[#FFF9E6]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/>
                </svg>
              </div>
              <p class="text-gray-700 leading-relaxed" style="font-size: 16px;">
                Outstanding electrical work for our commercial space. They handled everything efficiently with minimal disruption to our business operations. The quality of work exceeded our expectations.
              </p>
            </div>
          </div>

          <!-- Testimonial 3 -->
          <div class="testimonial-slide min-w-full md:min-w-[50%] px-3">
            <div class="bg-white border-2 border-gray-200 rounded-lg p-8 h-full">
              <div class="flex items-start justify-between mb-6">
                <div class="flex items-center gap-4">
                  <img 
                    src="https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?w=100&h=100&fit=crop" 
                    alt="David Chen" 
                    class="w-16 h-16 rounded-full object-cover"
                  />
                  <div>
                    <h3 class="text-xl font-bold text-black">David Chen</h3>
                    <p class="text-[#F4C430] font-semibold">Property Manager</p>
                  </div>
                </div>
                <svg class="w-16 h-16 text-[#FFF9E6]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/>
                </svg>
              </div>
              <p class="text-gray-700 leading-relaxed" style="font-size: 16px;">
                Reliable and trustworthy electricians. They've handled multiple panel upgrades across our properties with consistent quality. Their emergency response time is impressive and pricing is fair.
              </p>
            </div>
          </div>

          <!-- Testimonial 4 -->
          <div class="testimonial-slide min-w-full md:min-w-[50%] px-3">
            <div class="bg-white border-2 border-gray-200 rounded-lg p-8 h-full">
              <div class="flex items-start justify-between mb-6">
                <div class="flex items-center gap-4">
                  <img 
                    src="https://images.unsplash.com/photo-1580489944761-15a19d654956?w=100&h=100&fit=crop" 
                    alt="Emily Martinez" 
                    class="w-16 h-16 rounded-full object-cover"
                  />
                  <div>
                    <h3 class="text-xl font-bold text-black">Emily Martinez</h3>
                    <p class="text-[#F4C430] font-semibold">Restaurant Owner</p>
                  </div>
                </div>
                <svg class="w-16 h-16 text-[#FFF9E6]" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/>
                </svg>
              </div>
              <p class="text-gray-700 leading-relaxed" style="font-size: 16px;">
                Professional team that understands commercial needs. They upgraded our restaurant's electrical system efficiently and ensured everything met code requirements. Excellent communication throughout the project.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Navigation Arrows -->
      <button 
        class="carousel-prev absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 bg-[#F4C430] text-black w-12 h-12 rounded-full flex items-center justify-center hover:bg-[#e5b52a] transition-colors z-10"
        aria-label="Previous testimonial"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>
      <button 
        class="carousel-next absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 bg-[#F4C430] text-black w-12 h-12 rounded-full flex items-center justify-center hover:bg-[#e5b52a] transition-colors z-10"
        aria-label="Next testimonial"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </button>

      <!-- Dots Navigation -->
      <div class="flex justify-center gap-2 mt-8">
        <button class="carousel-dot w-3 h-3 rounded-full bg-[#F4C430] transition-all" data-index="0"></button>
        <button class="carousel-dot w-3 h-3 rounded-full bg-gray-300 transition-all" data-index="1"></button>
        <button class="carousel-dot w-3 h-3 rounded-full bg-gray-300 transition-all" data-index="2"></button>
        <button class="carousel-dot w-3 h-3 rounded-full bg-gray-300 transition-all" data-index="3"></button>
      </div>
    </div>
  </div>
</section>

<script>
  let currentIndex = 0;
  const track = document.querySelector('.testimonial-track') as HTMLElement;
  const slides = document.querySelectorAll('.testimonial-slide');
  const dots = document.querySelectorAll('.carousel-dot');
  const prevBtn = document.querySelector('.carousel-prev');
  const nextBtn = document.querySelector('.carousel-next');
  
  // Determine slides per view based on screen size
  function getSlidesPerView() {
    return window.innerWidth >= 768 ? 2 : 1;
  }
  
  const totalSlides = slides.length;
  
  function updateCarousel() {
    const slidesPerView = getSlidesPerView();
    const maxIndex = totalSlides - slidesPerView;
    
    // Ensure currentIndex is within bounds
    if (currentIndex > maxIndex) {
      currentIndex = maxIndex;
    }
    
    const offset = -(currentIndex * (100 / slidesPerView));
    track.style.transform = `translateX(${offset}%)`;
    
    // Update dots
    dots.forEach((dot, index) => {
      if (index === currentIndex) {
        dot.classList.remove('bg-gray-300');
        dot.classList.add('bg-[#F4C430]');
      } else {
        dot.classList.remove('bg-[#F4C430]');
        dot.classList.add('bg-gray-300');
      }
    });
  }
  
  function nextSlide() {
    const slidesPerView = getSlidesPerView();
    const maxIndex = totalSlides - slidesPerView;
    currentIndex = currentIndex >= maxIndex ? 0 : currentIndex + 1;
    updateCarousel();
  }
  
  function prevSlide() {
    const slidesPerView = getSlidesPerView();
    const maxIndex = totalSlides - slidesPerView;
    currentIndex = currentIndex <= 0 ? maxIndex : currentIndex - 1;
    updateCarousel();
  }
  
  // Event listeners
  nextBtn?.addEventListener('click', nextSlide);
  prevBtn?.addEventListener('click', prevSlide);
  
  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      currentIndex = index;
      updateCarousel();
    });
  });
  
  // Auto-play carousel
  let autoplayInterval = setInterval(nextSlide, 5000);
  
  // Pause on hover
  const carousel = document.querySelector('.testimonial-carousel');
  carousel?.addEventListener('mouseenter', () => {
    clearInterval(autoplayInterval);
  });
  
  carousel?.addEventListener('mouseleave', () => {
    autoplayInterval = setInterval(nextSlide, 5000);
  });
  
  // Handle window resize
  window.addEventListener('resize', updateCarousel);
  
  // Initial update
  updateCarousel();
</script>
