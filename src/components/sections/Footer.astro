---
// Footer component for electrician website
---

<footer class="bg-black text-white">
  <!-- Main Footer Content -->
  <div class="py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <!-- Top Section: Logo, Tagline, Newsletter -->
      <div class="mb-12 flex flex-col lg:flex-row justify-between items-start lg:items-center gap-8">
        <div class="max-w-md">
          <div class="flex items-center gap-3 mb-4">
            <img src="/logo.svg" alt="Electrixa Logo" class="h-10 w-10" />
            <h2 class="text-white font-bold" style="font-size: 25px;">
              ELECTRIXA
            </h2>
          </div>
          <p class="text-gray-400" style="font-size: 14px;">
            Creating Connection, and Shaping Futures, where Every Experience Matters.
          </p>
        </div>

        <!-- Newsletter -->
        <div class="flex gap-2 w-full lg:w-auto">
          <input 
            type="email" 
            placeholder="Email" 
            class="bg-transparent border-b-2 border-gray-600 text-white px-4 py-3 focus:outline-none focus:border-[#F4C430] transition-colors flex-1 lg:w-64"
          />
          <button class="bg-[#F4C430] text-black px-8 py-3 font-bold hover:bg-[#e5b52a] transition-colors">
            Send
          </button>
        </div>
      </div>

      <!-- Footer Columns -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
        <!-- Agency Column -->
        <div>
          <h3 class="text-white font-bold text-xl mb-4">Agency :</h3>
          <p class="text-gray-400 mb-6" style="font-size: 14px;">
            With a commitment to excellence, we thrive in delivering exceptional solutions and building lasting partnerships. Our journey is defined by a relentless pursuit of growth.
          </p>
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-[#F4C430] rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
              </svg>
            </div>
            <div>
              <p class="text-gray-400 text-sm">Call Us</p>
              <p class="text-white font-bold">+1 233 587 38</p>
            </div>
          </div>
        </div>

        <!-- Info Column -->
        <div>
          <h3 class="text-white font-bold text-xl mb-4">Info :</h3>
          <ul class="space-y-3">
            <li>
              <a href="/shipping" class="text-gray-400 hover:text-[#F4C430] transition-colors flex items-center gap-2" style="font-size: 14px;">
                <span class="text-[#F4C430]">›</span> Shipping Times
              </a>
            </li>
            <li>
              <a href="/products" class="text-gray-400 hover:text-[#F4C430] transition-colors flex items-center gap-2" style="font-size: 14px;">
                <span class="text-[#F4C430]">›</span> See all products
              </a>
            </li>
            <li>
              <a href="/payment" class="text-gray-400 hover:text-[#F4C430] transition-colors flex items-center gap-2" style="font-size: 14px;">
                <span class="text-[#F4C430]">›</span> Payment methods
              </a>
            </li>
            <li>
              <a href="/returns" class="text-gray-400 hover:text-[#F4C430] transition-colors flex items-center gap-2" style="font-size: 14px;">
                <span class="text-[#F4C430]">›</span> Returns and refunds
              </a>
            </li>
            <li>
              <a href="/terms" class="text-gray-400 hover:text-[#F4C430] transition-colors flex items-center gap-2" style="font-size: 14px;">
                <span class="text-[#F4C430]">›</span> Terms and conditions
              </a>
            </li>
          </ul>
        </div>

        <!-- Contacts Column -->
        <div>
          <h3 class="text-white font-bold text-xl mb-4">Contacts :</h3>
          <ul class="space-y-3">
            <li>
              <a href="#" class="text-gray-400 hover:text-[#F4C430] transition-colors flex items-center gap-2" style="font-size: 14px;">
                <span class="text-[#F4C430]">›</span> Molly Mc Drive
              </a>
            </li>
            <li>
              <a href="mailto:info@email.com" class="text-gray-400 hover:text-[#F4C430] transition-colors flex items-center gap-2" style="font-size: 14px;">
                <span class="text-[#F4C430]">›</span> info@email.com
              </a>
            </li>
            <li>
              <a href="#" class="text-gray-400 hover:text-[#F4C430] transition-colors flex items-center gap-2" style="font-size: 14px;">
                <span class="text-[#F4C430]">›</span> Emily Burton
              </a>
            </li>
            <li>
              <a href="mailto:quote@email.com" class="text-gray-400 hover:text-[#F4C430] transition-colors flex items-center gap-2" style="font-size: 14px;">
                <span class="text-[#F4C430]">›</span> quote@email.com
              </a>
            </li>
            <li>
              <a href="#" class="text-gray-400 hover:text-[#F4C430] transition-colors flex items-center gap-2" style="font-size: 14px;">
                <span class="text-[#F4C430]">›</span> U.S. of America
              </a>
            </li>
          </ul>
        </div>

        <!-- Recent Posts Column -->
        <div>
          <h3 class="text-white font-bold text-xl mb-4">Recent Posts :</h3>
          <div class="space-y-4">
            <!-- Post 1 -->
            <div class="flex gap-3">
              <img 
                src="https://images.unsplash.com/photo-1621905251918-48416bd8575a?w=100&h=100&fit=crop" 
                alt="Light Poles" 
                class="w-16 h-16 object-cover rounded"
              />
              <div>
                <h4 class="text-white font-semibold text-sm mb-1">Light Poles & Prevention</h4>
                <p class="text-gray-400 text-xs">With recent advances in technology, light poles</p>
              </div>
            </div>
            <!-- Post 2 -->
            <div class="flex gap-3">
              <img 
                src="https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?w=100&h=100&fit=crop" 
                alt="Prevention" 
                class="w-16 h-16 object-cover rounded"
              />
              <div>
                <h4 class="text-white font-semibold text-sm mb-1">Prevention & Support</h4>
                <p class="text-gray-400 text-xs">Electricians are essential to the safety and</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Footer -->
  <div class="border-t border-gray-800 py-6 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
      <!-- Logo -->
      <div class="flex items-center gap-3">
        <img src="/logo.svg" alt="Electrixa Logo" class="h-8 w-8" />
        <span class="text-white font-bold text-xl">ELECTRIXA</span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6">
        <a href="/partnerships" class="text-gray-400 hover:text-[#F4C430] transition-colors text-sm">Partnerships</a>
        <span class="text-gray-600">•</span>
        <a href="/support" class="text-gray-400 hover:text-[#F4C430] transition-colors text-sm">Customer Support</a>
        <span class="text-gray-600">•</span>
        <a href="/privacy" class="text-gray-400 hover:text-[#F4C430] transition-colors text-sm">Privacy Policy</a>
      </div>

      <!-- Social Icons -->
      <div class="flex items-center gap-4">
        <a href="#" class="w-10 h-10 bg-[#F4C430] rounded-full flex items-center justify-center hover:bg-[#e5b52a] transition-colors">
          <svg class="w-5 h-5 text-black" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
        <a href="#" class="w-10 h-10 bg-[#F4C430] rounded-full flex items-center justify-center hover:bg-[#e5b52a] transition-colors">
          <svg class="w-5 h-5 text-black" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
          </svg>
        </a>
        <a href="#" class="w-10 h-10 bg-[#F4C430] rounded-full flex items-center justify-center hover:bg-[#e5b52a] transition-colors">
          <svg class="w-5 h-5 text-black" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
