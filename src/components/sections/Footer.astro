---
// Footer component for electrician website
---

<footer class="bg-black text-white">
  <!-- Main Footer Content -->
  <div class="pt-16 pb-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <!-- Top Section: Logo, Tagline, Quick Links, Services -->
      <div class="mb-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
        <div class="max-w-md">
          <div class="flex items-center gap-3 mb-4">
            <img src="/logo.svg" alt="Electrixa Logo" class="h-10 w-10" />
            <h2 class="text-white font-bold" style="font-size: 25px;">
              ELECTRIXA
            </h2>
          </div>
          <p class="text-gray-400" style="font-size: 16px;">
            With a commitment to excellence, we thrive in delivering exceptional solutions and building lasting partnerships. Our journey is defined by a relentless pursuit of growth.
          </p>
        </div>

        <!-- Quick Links -->
        <div class="lg:ml-8">
          <h3 class="text-white font-bold text-xl mb-4">Quick Links</h3>
          <ul class="space-y-3">
            <li>
              <a href="#home" class="text-gray-400 hover:text-[#F4C430] transition-colors flex items-center gap-2" style="font-size: 16px;">
                <span class="text-[#F4C430]">›</span> Home
              </a>
            </li>
            <li>
              <a href="#about" class="text-gray-400 hover:text-[#F4C430] transition-colors flex items-center gap-2" style="font-size: 16px;">
                <span class="text-[#F4C430]">›</span> About Us
              </a>
            </li>
            <li>
              <a href="#services" class="text-gray-400 hover:text-[#F4C430] transition-colors flex items-center gap-2" style="font-size: 16px;">
                <span class="text-[#F4C430]">›</span> Services
              </a>
            </li>
            <li>
              <a href="#testimonials" class="text-gray-400 hover:text-[#F4C430] transition-colors flex items-center gap-2" style="font-size: 16px;">
                <span class="text-[#F4C430]">›</span> Testimonials
              </a>
            </li>
            <li>
              <a href="#contact" class="text-gray-400 hover:text-[#F4C430] transition-colors flex items-center gap-2" style="font-size: 16px;">
                <span class="text-[#F4C430]">›</span> Contact
              </a>
            </li>
          </ul>
        </div>

        <!-- Services -->
        <div>
          <h3 class="text-white font-bold text-xl mb-4">Services</h3>
          <ul class="space-y-3">
            <li>
              <a href="#services" class="text-gray-400 hover:text-[#F4C430] transition-colors flex items-center gap-2" style="font-size: 16px;">
                <span class="text-[#F4C430]">›</span> Commercial Electrical
              </a>
            </li>
            <li>
              <a href="#services" class="text-gray-400 hover:text-[#F4C430] transition-colors flex items-center gap-2" style="font-size: 16px;">
                <span class="text-[#F4C430]">›</span> Residential Electrical
              </a>
            </li>
            <li>
              <a href="#services" class="text-gray-400 hover:text-[#F4C430] transition-colors flex items-center gap-2" style="font-size: 16px;">
                <span class="text-[#F4C430]">›</span> Specialty Services
              </a>
            </li>
            <li>
              <a href="#services" class="text-gray-400 hover:text-[#F4C430] transition-colors flex items-center gap-2" style="font-size: 16px;">
                <span class="text-[#F4C430]">›</span> Emergency
              </a>
            </li>
          </ul>
        </div>

        <!-- Contact Info -->
        <div>
          <h3 class="text-white font-bold text-xl mb-4">Contact</h3>
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-[#F4C430] rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-black" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                </svg>
              </div>
              <div>
                <p class="text-gray-400 text-sm">Call Us</p>
                <p class="text-white font-bold">+(234) 567 8912</p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-[#F4C430] rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-black" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                </svg>
              </div>
              <div>
                <p class="text-gray-400 text-sm">Email Us</p>
                <p class="text-white font-bold">info@electrixa.com</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Footer -->
  <div class="border-t border-gray-800 py-6 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
      <!-- Links -->
      <div class="flex items-center gap-6">
        <a href="/partnerships" class="text-gray-400 hover:text-[#F4C430] transition-colors" style="font-size: 13px;">Partnerships</a>
        <span class="text-gray-600">•</span>
        <a href="/support" class="text-gray-400 hover:text-[#F4C430] transition-colors" style="font-size: 13px;">Customer Support</a>
        <span class="text-gray-600">•</span>
        <a href="/privacy" class="text-gray-400 hover:text-[#F4C430] transition-colors" style="font-size: 13px;">Privacy Policy</a>
      </div>

      <!-- Social Icons -->
      <div class="flex items-center gap-4">
        <a href="#" class="w-10 h-10 bg-[#F4C430] rounded-full flex items-center justify-center hover:bg-[#e5b52a] transition-colors">
          <svg class="w-5 h-5 text-black" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
        <a href="#" class="w-10 h-10 bg-[#F4C430] rounded-full flex items-center justify-center hover:bg-[#e5b52a] transition-colors">
          <svg class="w-5 h-5 text-black" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
          </svg>
        </a>
        <a href="#" class="w-10 h-10 bg-[#F4C430] rounded-full flex items-center justify-center hover:bg-[#e5b52a] transition-colors">
          <svg class="w-5 h-5 text-black" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
