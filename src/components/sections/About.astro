---
// About component for electrician website
import Button from '../ui/Button.astro';
---

<section class="bg-white py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-end">
      <!-- Left Side - Images and Stats -->
      <div class="relative h-[650px]">
        <!-- Background Image (Buildings) - Top Left, tall and narrow -->
        <div class="absolute top-0 left-0 w-[450px] h-[580px] rounded-lg overflow-hidden shadow-xl z-10">
          <img 
            src="https://images.unsplash.com/photo-1622426385889-4fc93a72423a?q=80&w=746&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" 
            alt="Buildings" 
            class="w-full h-full object-cover"
          />
        </div>

        <!-- Main Image (Electrician) - Bottom Right, larger -->
        <div class="absolute bottom-0 right-0 w-96 h-[420px] rounded-lg overflow-hidden shadow-xl z-20">
          <img 
            src="https://images.unsplash.com/photo-1683295083329-4d4738291f3a?q=80&w=687&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" 
            alt="Electrician at work" 
            class="w-full h-full object-cover"
          />
        </div>

        <!-- Experience Card - Positioned at top-right overlapping both images -->
        <div class="absolute top-36 right-16 bg-[#F4C430] p-8 rounded-lg shadow-2xl z-30 w-55 border-t-4 border-black">
          <div class="flex flex-col items-start space-y-2">
            <h3 class="text-7xl font-black text-black tracking-tight counter" data-target="20" style="line-height: 0.9; min-width: 150px;">0+</h3>
            <div class="text-left">
              <p class="text-lg font-bold text-black leading-tight">Years of</p>
              <p class="text-lg font-bold text-black leading-tight">Experiences</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Side - Content -->
      <div class="space-y-6">
        <div>
          <p class="text-[#F4C430] font-semibold mb-2" style="font-size: 18px;">About Us</p>
          <h2 class="heading-h2 font-bold text-black mb-4" style="line-height: 1.2;">Reliable & Expert<br><span class="whitespace-nowrap">Electrical Solutions</span></h2>
          <p class="text-gray-700 leading-relaxed" style="font-size: 22px;">
            With over two decades of experience, we deliver professional electrical services that prioritize safety, efficiency, and innovation. Our certified team ensures every project meets the highest standards.
          </p>
        </div>

        <!-- Mission and Vision Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Our Mission -->
          <div class="border border-gray-200 rounded-lg p-6 hover:border-[#F4C430] transition-all">
            <div class="w-12 h-12 bg-[#F4F4F4] rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[#F4C430]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-black mb-2">Our Mission</h3>
            <p class="text-gray-700">
              To provide reliable, safe, and innovative solutions that power homes and businesses.
            </p>
          </div>

          <!-- Our Vision -->
          <div class="border border-gray-200 rounded-lg p-6 hover:border-[#F4C430] transition-all">
            <div class="w-12 h-12 bg-[#F4F4F4] rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[#F4C430]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-black mb-2">Our Vision</h3>
            <p class="text-gray-700">
              To be the most trusted service provider, setting industry standards for excellence.
            </p>
          </div>
        </div>

        <!-- About More Button and Founder -->
        <div class="flex items-center gap-6 pt-2">
          <Button href="/about" variant="accent" size="md" icon={false}>
            About More
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Counter animation for the experience card
  const counter = document.querySelector('.counter');
  if (counter) {
    const target = parseInt(counter.getAttribute('data-target') || '0');
    let current = 0;
    const increment = target / 30; // Faster animation
    const duration = 1000; // 1 second instead of 2
    const stepTime = duration / 30;

    const updateCounter = () => {
      current += increment;
      if (current < target) {
        counter.textContent = Math.floor(current) + '+';
        setTimeout(updateCounter, stepTime);
      } else {
        counter.textContent = target + '+';
      }
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          updateCounter();
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.5 });

    observer.observe(counter);
  }
</script>
