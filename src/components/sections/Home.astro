---
import Button from '../ui/Button.astro';

interface Props {
    backgroundImage?: string;
    subtitle?: string;
    ctaText?: string;
    ctaLink?: string;
}

const {
    backgroundImage = "https://unsplash.com/photos/man-on-green-galvanized-iron-sheet-holding-green-bar-Lgaw-BnaAAI",
    subtitle = "Brightening lives with reliable electrical solutions, one connection at a time",
    ctaText = "EXPLORE NOW",
    ctaLink = "/contact",
} = Astro.props;
---

<section
    id="hero-section"
    class="relative w-full flex items-center justify-center overflow-hidden"
    style="height: 90vh;"
>
    <!-- Background Image -->
    <img 
        src={backgroundImage}
        alt="Electrical services hero background"
        class="absolute inset-0 w-full h-full object-cover"
        fetchpriority="high"
    />
    
    <!-- Dark Overlay -->
    <div class="absolute inset-0 bg-black/50"></div>

    <!-- Content -->
    <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-1 text-left">
        <!-- Main Title -->
        <h1
            class="font-heading font-bold text-white mb-1 tracking-wider animate-title mobile-title break-words"
            style="font-size: 80px; line-height: 1.2; max-width: 100%;"
        >
            POWERING YOUR <span id="rotating-word" class="text-[#F4C430]"></span>
        </h1>

        <!-- Subtitle -->
        {
            subtitle && (
                <p class="text-subtitle font-body text-white mb-10 font-light tracking-wide animate-subtitle">
                    {subtitle}
                </p>
            )
        }

        <!-- Explore Now Button & Rating -->
        {
            ctaText && ctaLink && (
                <div class="flex flex-col sm:flex-row items-start sm:items-center gap-10">
                    <div class="animate-button">
                        <Button href={ctaLink} variant="accent" size="md">
                            {ctaText}
                        </Button>
                    </div>
                    
                    <!-- Rating Display -->
                    <div class="flex items-center gap-4 animate-rating">
                        <div class="text-left">
                            <div class="font-bold text-white" style="font-size: 50px;">4.9</div>
                        </div>
                        <div class="flex flex-col gap-1">
                            <div class="flex gap-1">
                                {[...Array(5)].map(() => (
                                    <svg class="w-5 h-5 text-[#F4C430]" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                    </svg>
                                ))}
                            </div>
                            <div class="text-white text-lg font-light">356 Client reviews</div>
                        </div>
                    </div>
                </div>
            )
        }
    </div>
</section>

<style>
    /* Mobile title size override */
    @media (max-width: 425px) {
        .mobile-title {
            font-size: 60px !important;
        }
    }

    @media (min-width: 426px) and (max-width: 767px) {
        .mobile-title {
            font-size: 30px !important;
        }
    }

    @media (min-width: 768px) and (max-width: 1023px) {
        .mobile-title {
            font-size: 48px !important;
        }
    }

    #rotating-word {
        display: inline-block;
        min-width: 100px;
        text-align: left;
        transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    }

    @media (min-width: 426px) {
        #rotating-word {
            min-width: 150px;
        }
    }

    @media (min-width: 768px) {
        #rotating-word {
            min-width: 200px;
        }
    }

    @media (min-width: 1024px) {
        #rotating-word {
            min-width: 250px;
        }
    }

    #rotating-word.fade-out {
        opacity: 0;
        transform: translateY(-30px) scale(0.8);
    }

    #rotating-word.fade-in {
        opacity: 1;
        transform: translateY(0) scale(1);
    }

    /* Page load animations */
    .animate-title {
        opacity: 0;
        animation: slideInFromLeft 1s ease-out forwards;
    }

    .animate-subtitle {
        opacity: 0;
        animation: slideInFromLeft 1s ease-out 0.3s forwards;
    }

    .animate-button {
        opacity: 0;
        animation: slideInFromLeft 1s ease-out 0.6s forwards;
    }

    .animate-rating {
        opacity: 0;
        animation: slideInFromRight 1s ease-out 0.9s forwards;
    }

    @keyframes slideInFromLeft {
        0% {
            opacity: 0;
            transform: translateX(-50px);
        }
        100% {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @keyframes slideInFromRight {
        0% {
            opacity: 0;
            transform: translateX(50px);
        }
        100% {
            opacity: 1;
            transform: translateX(0);
        }
    }
</style>

<script>
    const words = ['HOME', 'BUSINESS', 'FUTURE', 'WORLD'];
    let currentIndex = 0;
    const element = document.getElementById('rotating-word');
    
    function rotateWord() {
        if (element) {
            // Fade out with animation
            element.classList.remove('fade-in');
            element.classList.add('fade-out');
            
            setTimeout(() => {
                // Change word
                currentIndex = (currentIndex + 1) % words.length;
                element.textContent = words[currentIndex];
                
                // Fade in with animation
                element.classList.remove('fade-out');
                element.classList.add('fade-in');
            }, 500);
        }
    }
    
    // Set initial word
    if (element) {
        element.textContent = words[0];
        element.classList.add('fade-in');
    }
    
    // Rotate every 3 seconds
    setInterval(rotateWord, 3000);
</script>
