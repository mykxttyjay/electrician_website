---
import Button from '../ui/Button.astro';

interface Props {
    backgroundImage?: string;
    subtitle?: string;
    ctaText?: string;
    ctaLink?: string;
}

const {
    backgroundImage = "https://unsplash.com/photos/man-on-green-galvanized-iron-sheet-holding-green-bar-Lgaw-BnaAAI",
    subtitle = "Brightening lives with reliable electrical solutions, one connection at a time",
    ctaText = "EXPLORE NOW",
    ctaLink = "/contact",
} = Astro.props;
---

<section
    id="hero-section"
    class="relative w-full flex items-center justify-center overflow-hidden"
    style="height: 90vh;"
>
    <!-- Background Images with Crossfade -->
    <div 
        data-bg-index="0"
        class="absolute inset-0 w-full h-full bg-cover bg-center bg-fixed transition-opacity duration-1000 opacity-100"
        style="background-image: url('https://images.unsplash.com/photo-1760886801783-e2d0522dd2c3?q=80&w=1170&auto=format&fit=crop');"
    ></div>
    <div 
        data-bg-index="1"
        class="absolute inset-0 w-full h-full bg-cover bg-center bg-fixed transition-opacity duration-1000 opacity-0"
        style="background-image: url('https://images.unsplash.com/photo-1581090581500-58b180d1f0fd?q=80&w=1170&auto=format&fit=crop');"
    ></div>
    <div 
        data-bg-index="2"
        class="absolute inset-0 w-full h-full bg-cover bg-center bg-fixed transition-opacity duration-1000 opacity-0"
        style="background-image: url('https://images.unsplash.com/photo-1543489816-c87b0f5f7dd4?q=80&w=1170&auto=format&fit=crop');"
    ></div>
    <div 
        data-bg-index="3"
        class="absolute inset-0 w-full h-full bg-cover bg-center bg-fixed transition-opacity duration-1000 opacity-0"
        style="background-image: url('https://images.unsplash.com/photo-1509391366360-2e959784a276?q=80&w=1172&auto=format&fit=crop');"
    ></div>
    
    <!-- Dark Overlay -->
    <div class="absolute inset-0 bg-black/50"></div>

    <!-- Content -->
    <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-1 text-left">
        <!-- Main Title -->
        <h1
            class="font-heading font-bold text-white mb-1 tracking-wider opacity-0 animate-[slideInFromLeft_1s_ease-out_forwards] text-[60px] xs:text-[30px] sm:text-[30px] md:text-[48px] lg:text-[80px] break-words"
            style="line-height: 1.2; max-width: 100%;"
        >
            POWERING YOUR <span id="rotating-word" class="text-[#F4C430] inline-block min-w-[100px] xs:min-w-[150px] md:min-w-[200px] lg:min-w-[250px] text-left transition-all duration-500 ease-[cubic-bezier(0.68,-0.55,0.265,1.55)]"></span>
        </h1>

        <!-- Subtitle -->
        {
            subtitle && (
                <p class="text-subtitle font-body text-white mb-10 font-light tracking-wide opacity-0 animate-[slideInFromLeft_1s_ease-out_0.3s_forwards]">
                    {subtitle}
                </p>
            )
        }

        <!-- Explore Now Button & Rating -->
        {
            ctaText && ctaLink && (
                <div class="flex flex-col sm:flex-row items-start sm:items-center gap-10">
                    <div class="opacity-0 animate-[slideInFromLeft_1s_ease-out_0.6s_forwards]">
                        <Button href={ctaLink} variant="accent" size="md">
                            {ctaText}
                        </Button>
                    </div>
                    
                    <!-- Rating Display -->
                    <div class="flex items-center gap-4 opacity-0 animate-[slideInFromRight_1s_ease-out_0.9s_forwards]">
                        <div class="text-left">
                            <div class="font-bold text-white" style="font-size: 50px;">4.9</div>
                        </div>
                        <div class="flex flex-col gap-1">
                            <div class="flex gap-1">
                                {[...Array(5)].map(() => (
                                    <svg class="w-5 h-5 text-[#F4C430]" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                    </svg>
                                ))}
                            </div>
                            <div class="text-white text-lg font-light">534 Client Reviews</div>
                        </div>
                    </div>
                </div>
            )
        }
    </div>
</section>

<script>
    const words = ['HOME', 'BUSINESS', 'FUTURE', 'WORLD'];
    let currentIndex = 0;
    const element = document.getElementById('rotating-word');
    const bgImages = document.querySelectorAll('[data-bg-index]');
    
    function rotateWord() {
        if (element && bgImages.length > 0) {
            // Calculate next index
            const nextIndex = (currentIndex + 1) % words.length;
            
            // Fade out word with animation
            element.classList.remove('opacity-100', 'translate-y-0', 'scale-100');
            element.classList.add('opacity-0', '-translate-y-[30px]', 'scale-[0.8]');
            
            // Crossfade backgrounds simultaneously - new fades in while old fades out
            bgImages[nextIndex].classList.remove('opacity-0');
            bgImages[nextIndex].classList.add('opacity-100');
            bgImages[currentIndex].classList.remove('opacity-100');
            bgImages[currentIndex].classList.add('opacity-0');
            
            setTimeout(() => {
                // Update index and word
                currentIndex = nextIndex;
                element.textContent = words[currentIndex];
                
                // Fade in word with animation
                element.classList.remove('opacity-0', '-translate-y-[30px]', 'scale-[0.8]');
                element.classList.add('opacity-100', 'translate-y-0', 'scale-100');
            }, 500);
        }
    }
    
    // Set initial word
    if (element) {
        element.textContent = words[0];
        element.classList.add('opacity-100', 'translate-y-0', 'scale-100');
    }
    
    // Rotate every 3 seconds
    setInterval(rotateWord, 3000);
</script>
