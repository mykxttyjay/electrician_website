---
import Button from '../ui/Button.astro';
---

<section class="bg-[#1a1a1a] pt-12 pb-20 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img 
      src="https://images.unsplash.com/photo-1635335874521-7987db781153?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" 
      alt="Background" 
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-[#1a1a1a] opacity-90"></div>
  </div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="text-center cta-content opacity-0 translate-y-[30px]">
      <h2 class="heading-h2 font-bold text-white mb-6 leading-tight">
        Ready to Power Your Project?
      </h2>
      <p class="text-white text-xl mb-10 max-w-6xl mx-auto leading-relaxed">
        Get expert electrical solutions tailored to your needs - contact our team for reliable service.
      </p>

      <!-- Enhanced CTA Buttons -->
      <div class="flex flex-col md:flex-row justify-center items-stretch gap-6 mb-12">
        <!-- Primary CTA Button -->
        <div class="relative group">
          <Button variant="accent" size="lg" href="/contact" icon={false}>
            Contact Us Today
          </Button>
        </div>
 
        <!-- Phone CTA - Enhanced -->
        <a href="tel:+12345678912" class="group relative flex items-center h-full">
          <div class="absolute -inset-2 bg-[#F4C430] blur opacity-20 group-hover:opacity-40 transition duration-300"></div>
          <div class="relative bg-gradient-to-r from-[#1a1a1a] to-[#2a2a2a] border-2 border-[#F4C430] px-8 h-[68px] flex items-center gap-4 group-hover:border-[#e5b52a] transition-all duration-300 group-hover:scale-105">
            <div class="w-12 h-12 bg-[#F4C430] rounded-full flex items-center justify-center transition-colors relative flex-shrink-0">
              <svg class="w-6 h-6 text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
              </svg>
            </div>
            <div class="text-left">
              <p class="text-[#F4C430] font-bold text-sm uppercase tracking-wider">Call Us Now</p>
              <p class="text-white font-black text-xl tracking-tight">+(234) 567 8912</p>
            </div>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const ctaObserverOptions = {
    threshold: 0.2,
    rootMargin: '0px 0px -50px 0px'
  };

  const ctaObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate-[fadeInUp_0.8s_ease-out_forwards]');
        ctaObserver.unobserve(entry.target);
      }
    });
  }, ctaObserverOptions);

  const ctaContent = document.querySelector('.cta-content');
  if (ctaContent) ctaObserver.observe(ctaContent);
</script>

<style>
  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
