---
import Button from '../ui/Button.astro';
---

<section class="bg-white py-0 px-0 relative overflow-hidden">
  <!-- Full Section Background Image -->
  <div class="absolute inset-0 bg-cover bg-center bg-fixed" style="background-image: url('https://images.unsplash.com/photo-1582481024061-4be0e115414f?q=80&w=1179&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');"></div>
  
  <div class="max-w-full mx-auto relative">
    <div class="grid lg:grid-cols-4">
      <!-- Left Side - Experience/Stats with Yellow Overlay -->
      <div class="relative lg:col-span-1 py-8 overflow-hidden">
        <!-- Yellow Gradient Overlay (only on left side) -->
        <div class="absolute inset-0 bg-[#F4C430] opacity-90"></div>

        <!-- Content -->
        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-left ml-0 mt-0">  <!-- Adjust ml-0 (horizontal) and mt-0 (vertical) values -->
            <div class="mb-4 ml-48">
              <div class="text-white">
                <div class="text-[75px] font-black leading-none mt-4">24/7</div>
                <div class="text-xl font-semibold tracking-wider mt-4">Emergency</div>
                <div class="text-xl font-semibold tracking-wider">Electrical</div>
                <div class="text-xl font-semibold tracking-wider">Service</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Side - Contact Information -->
      <div class="relative lg:col-span-3 py-8 overflow-hidden">
        <!-- White Overlay (only on right side) -->
        <div class="absolute inset-0 bg-white/90"></div>
        
        <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-[61px] font-bold text-black mb-4 leading-tight">
            Have Questions? <span class="text-[#F4C430]">+(234) 567 8912</span>
          </h2>
          <p class="text-gray-600 text-lg mb-6 leading-relaxed">
            We provide the best team that can do anything for you. We have a reliable company & our work is trusted.
          </p>

          <!-- CTA Button -->
          <div class="inline-block">
            <Button variant="accent" size="md" href="tel:+2345678912">
              CALL US NOW
            </Button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

