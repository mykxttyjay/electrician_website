---
interface Props {
  title: string;
  backgroundImage?: string;
  titleSize?: string;
}

const { 
  title, 
  backgroundImage = "https://images.unsplash.com/photo-1683094113822-36663c546b0b?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
  titleSize = "heading-h1"
} = Astro.props;
---

<!-- Hero Section -->
<section class="relative text-white px-4 sm:px-6 lg:px-8" style="padding-top: 140px; padding-bottom: 80px; margin-top: 70px;">
    <!-- Background Image with Black & White Filter -->
    <div 
        class="absolute inset-0 bg-cover bg-center grayscale"
        style={`background-image: url('${backgroundImage}');`}
    >
    ></div>
    <!-- Dark Overlay -->
    <div class="absolute inset-0 bg-black/50"></div>
    
    <!-- Content -->
    <div class="relative max-w-7xl mx-auto text-center">
        <h1 class={`${titleSize} font-bold mb-4`}>{title}</h1>
    </div>
</section>
