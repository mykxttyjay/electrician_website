---
import Button from '../ui/Button.astro';

const slides = [
  {
    icon: 'lightning',
    highlight: 'Licensed & Insured',
    title: 'We are',
    titleAfter: 'company',
    description: 'It is a long established fact that a reader will be distracted by quality electrical services'
  },
  {
    icon: 'shield',
    highlight: '24/7 Available',
    title: 'We provide',
    titleAfter: 'service',
    description: 'Emergency electrical services available round the clock for your peace of mind'
  },
  {
    icon: 'certificate',
    highlight: 'Certified Experts',
    title: 'We have',
    titleAfter: 'team',
    description: 'Highly trained and certified electricians ready to handle all your electrical needs'
  }
];
---

<section class="bg-[#1a1a1a] py-16 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <!-- Carousel Container -->
    <div class="relative">
      {slides.map((slide, index) => (
        <div 
          class={`carousel-slide transition-opacity duration-500 ${index === 0 ? 'opacity-100' : 'opacity-0 absolute inset-0'}`}
          data-slide-index={index}
        >
          <div class="flex flex-col md:flex-row items-center justify-between gap-8">
            <!-- Left Side: Icon -->
            <div class="flex-shrink-0">
              <div class="w-20 h-20 bg-[#F4C430] flex items-center justify-center">
                {slide.icon === 'lightning' && (
                  <svg class="w-12 h-12 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  </svg>
                )}
                {slide.icon === 'shield' && (
                  <svg class="w-12 h-12 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                )}
                {slide.icon === 'certificate' && (
                  <svg class="w-12 h-12 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                  </svg>
                )}
              </div>
            </div>

            <!-- Center: Text Content -->
            <div class="flex-1 text-center md:text-left">
              <h2 class="text-white text-3xl md:text-4xl font-bold mb-2">
                {slide.title} <span class="bg-[#F4C430] text-black px-3 py-1">{slide.highlight}</span> {slide.titleAfter}
              </h2>
              <p class="text-gray-300 text-lg">
                {slide.description}
              </p>
            </div>

            <!-- Right Side: CTA Button -->
            <div class="flex-shrink-0">
              <Button href="/contact" variant="accent" size="lg">
                GET A FREE QUOTE
              </Button>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Sliding Indicators -->
    <div class="hidden flex justify-center md:justify-end gap-2 mt-8">
      {slides.map((_, index) => (
        <button 
          class={`indicator w-3 h-3 rounded-full transition-all ${index === 0 ? 'bg-[#F4C430]' : 'bg-gray-600 hover:bg-gray-500'}`}
          data-indicator-index={index}
          aria-label={`Go to slide ${index + 1}`}
        ></button>
      ))}
    </div>
  </div>
</section>

<script>
  let currentSlide = 0;
  const slides = document.querySelectorAll('.carousel-slide');
  const indicators = document.querySelectorAll('.indicator');
  const totalSlides = slides.length;

  function showSlide(index: number) {
    // Hide all slides
    slides.forEach(slide => {
      slide.classList.remove('opacity-100');
      slide.classList.add('opacity-0', 'absolute', 'inset-0');
    });

    // Show current slide
    slides[index].classList.remove('opacity-0', 'absolute', 'inset-0');
    slides[index].classList.add('opacity-100');

    // Update indicators
    indicators.forEach((indicator, i) => {
      if (i === index) {
        indicator.classList.remove('bg-gray-600');
        indicator.classList.add('bg-[#F4C430]');
      } else {
        indicator.classList.remove('bg-[#F4C430]');
        indicator.classList.add('bg-gray-600');
      }
    });

    currentSlide = index;
  }

  function nextSlide() {
    const next = (currentSlide + 1) % totalSlides;
    showSlide(next);
  }

  // Auto-rotate every 5 seconds
  let autoRotate = setInterval(nextSlide, 5000);

  // Manual navigation
  indicators.forEach((indicator, index) => {
    indicator.addEventListener('click', () => {
      showSlide(index);
      // Reset auto-rotate timer
      clearInterval(autoRotate);
      autoRotate = setInterval(nextSlide, 5000);
    });
  });
</script>
