---
// Coupons component for electrician website
---

<section class="bg-[#1a1a1a] py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <!-- Coupons Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Coupon 1: Senior & Military -->
      <div class="bg-white rounded-lg p-8 relative overflow-hidden shadow-xl">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gray-100 rounded-full -mr-16 -mt-16"></div>
        <div class="absolute bottom-0 left-0 w-24 h-24 bg-gray-100 rounded-full -ml-12 -mb-12"></div>
        <div class="relative z-10">
          <p class="text-black text-lg font-bold mb-2">Senior & Military</p>
          <h3 class="text-[#F4C430] text-4xl font-black mb-4">Coupon</h3>
          <p class="text-gray-700 text-sm mb-6">Redeem & Save Today</p>
          <div class="bg-[#1a1a1a] text-white text-center py-4 px-6 rounded-lg mb-6">
            <span class="text-3xl font-black">10%</span>
            <span class="text-xl font-bold ml-2">OFF</span>
          </div>
          <p class="text-gray-700 text-sm mb-4 leading-relaxed">
            Senior & Military Discount. Cannot be combined with any other offer.
          </p>
          <p class="text-gray-600 text-xs">* Offer Expires: December 2024</p>
        </div>
      </div>

      <!-- Coupon 2: Free Camera Inspection -->
      <div class="bg-gradient-to-br from-[#F4C430] to-[#e5b52a] rounded-lg p-8 relative overflow-hidden shadow-xl">
        <div class="absolute top-0 right-0 w-32 h-32 bg-black/10 rounded-full -mr-16 -mt-16"></div>
        <div class="absolute bottom-0 left-0 w-24 h-24 bg-black/10 rounded-full -ml-12 -mb-12"></div>
        <div class="relative z-10">
          <p class="text-black text-lg font-bold mb-2">Free Camera Inspection</p>
          <h3 class="text-black text-4xl font-black mb-4">Coupon</h3>
          <p class="text-black text-sm mb-6">Redeem & Save Today</p>
          <div class="bg-white text-[#1a1a1a] text-center py-4 px-6 rounded-lg mb-6">
            <span class="text-3xl font-black">FREE</span>
          </div>
          <p class="text-black text-sm mb-4 leading-relaxed">
            Sewer Camera Inspection with any standard "price" drain cleaning.
          </p>
          <p class="text-black text-xs">* Offer Expires: December 2024</p>
        </div>
      </div>

      <!-- Coupon 3: Electrical Service -->
      <div class="bg-white rounded-lg p-8 relative overflow-hidden shadow-xl">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gray-100 rounded-full -mr-16 -mt-16"></div>
        <div class="absolute bottom-0 left-0 w-24 h-24 bg-gray-100 rounded-full -ml-12 -mb-12"></div>
        <div class="relative z-10">
          <p class="text-black text-lg font-bold mb-2">Electrical Service</p>
          <h3 class="text-[#F4C430] text-4xl font-black mb-4">Coupon</h3>
          <p class="text-gray-700 text-sm mb-6">Redeem & Save Today</p>
          <div class="bg-[#1a1a1a] text-white text-center py-4 px-6 rounded-lg mb-6">
            <span class="text-3xl font-black">50%</span>
            <span class="text-xl font-bold ml-2">OFF</span>
          </div>
          <p class="text-gray-700 text-sm mb-4 leading-relaxed">
            Any Repair of $500 or More<br />
            Contact us now to get $50 Off today.
          </p>
          <p class="text-gray-600 text-xs">* Offer Expires: December 2024</p>
        </div>
      </div>
    </div>
  </div>
</section>
