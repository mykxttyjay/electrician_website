---
interface Props {
  show?: boolean;
  showOnScroll?: boolean;
  triggerSection?: string;
}

const { show = true, showOnScroll = false, triggerSection = 'coupons' } = Astro.props;
---

{show && (
  <!-- Floating Side Buttons - Left Side -->
  <div id="floating-side-buttons" class={`fixed left-4 top-1/2 -translate-y-1/2 z-40 hidden lg:flex flex-col gap-4 transition-opacity duration-300 ${showOnScroll ? 'opacity-0 pointer-events-none' : ''}`}>
    <!-- Specials Button -->
    <a 
      href="#" 
      class="group w-14 h-14 bg-black text-[#F4C430] flex items-center justify-center transition-all duration-300 hover:bg-[#F4C430] hover:text-black border-2 border-[#F4C430] shadow-lg hover:shadow-xl rounded-md"
      title="Specials"
    >
      <svg class="w-6 h-6 group-hover:rotate-[360deg] transition-transform duration-500" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    </a>
    
    <!-- Financing Button -->
    <a 
      href="#" 
      class="group w-14 h-14 bg-black text-[#F4C430] flex items-center justify-center transition-all duration-300 hover:bg-[#F4C430] hover:text-black border-2 border-[#F4C430] shadow-lg hover:shadow-xl rounded-md"
      title="Financing"
    >
      <svg class="w-6 h-6 group-hover:scale-125 transition-transform duration-300" fill="currentColor" viewBox="0 0 24 24">
        <path d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
)}

{showOnScroll && (
  <script define:vars={{ triggerSection }}>
    document.addEventListener('DOMContentLoaded', function() {
      const floatingSideButtons = document.getElementById('floating-side-buttons');
      const targetSection = document.getElementById(triggerSection);
      
      if (!floatingSideButtons || !targetSection) return;
      
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            // Target section is visible - show buttons
            floatingSideButtons.style.opacity = '1';
            floatingSideButtons.style.pointerEvents = 'auto';
          } else {
            // Target section is not visible - hide buttons
            floatingSideButtons.style.opacity = '0';
            floatingSideButtons.style.pointerEvents = 'none';
          }
        });
      }, {
        threshold: 0.1,
        rootMargin: '0px'
      });
      
      observer.observe(targetSection);
    });
  </script>
)}
