---
interface Props {
  show?: boolean;
  showOnScroll?: boolean;
  triggerSection?: string;
}

const { show = true, showOnScroll = false, triggerSection = 'coupons' } = Astro.props;
---

{show && (
  <!-- Floating Side Buttons - Left Side -->
  <div id="floating-side-buttons" class={`fixed left-4 top-1/2 -translate-y-1/2 z-40 hidden lg:flex flex-col gap-4 transition-all duration-500 ${showOnScroll ? 'opacity-0 pointer-events-none' : ''}`}>
    <!-- Specials Button -->
    <a 
      href="/specials" 
      class="group relative w-14 h-14 bg-black text-[#F4C430] flex items-center justify-center transition-all duration-500 hover:bg-[#F4C430] hover:text-black border-2 border-[#F4C430] shadow-lg hover:shadow-[0_10px_30px_rgba(244,196,48,0.6)] rounded-md overflow-hidden"
      title="Specials"
    >
      <!-- Shimmer effect -->
      <div class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-700 bg-gradient-to-r from-transparent via-white/40 to-transparent"></div>
      
      <!-- Pulsing ring -->
      <div class="absolute inset-0 border-2 border-[#F4C430] animate-[ping_1.5s_ease-in-out_infinite] opacity-75 rounded-md"></div>
      
      <svg class="relative w-6 h-6 group-hover:rotate-[360deg] transition-transform duration-500" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    </a>
    
    <!-- Financing Button -->
    <a 
      href="/financing" 
      class="group relative w-14 h-14 bg-black text-[#F4C430] flex items-center justify-center transition-all duration-500 hover:bg-[#F4C430] hover:text-black border-2 border-[#F4C430] shadow-lg hover:shadow-[0_10px_30px_rgba(244,196,48,0.6)] rounded-md overflow-hidden"
      title="Financing"
    >
      <!-- Shimmer effect -->
      <div class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-700 bg-gradient-to-r from-transparent via-white/40 to-transparent"></div>
      
      <!-- Pulsing ring -->
      <div class="absolute inset-0 border-2 border-[#F4C430] animate-[ping_1.5s_ease-in-out_infinite] opacity-75 rounded-md"></div>
      
      <svg class="relative w-6 h-6 group-hover:scale-125 transition-transform duration-500" fill="currentColor" viewBox="0 0 24 24">
        <path d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
)}

{showOnScroll && (
  <script define:vars={{ triggerSection }} is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      const floatingSideButtons = document.getElementById('floating-side-buttons');
      const targetSection = document.getElementById(triggerSection);
      const footer = document.querySelector('footer');
      
      if (!floatingSideButtons || !targetSection) return;
      
      // Track if we've scrolled past the trigger section
      let isPastTrigger = false;
      
      // Observer for trigger section - continuously observe
      const triggerObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          // Get the position of the section relative to viewport
          const rect = entry.target.getBoundingClientRect();
          const isAboveTrigger = rect.bottom < 0;
          
          if (isAboveTrigger) {
            // We've scrolled past the trigger section - show buttons
            isPastTrigger = true;
            floatingSideButtons.style.opacity = '1';
            floatingSideButtons.style.pointerEvents = 'auto';
          } else {
            // We're at or above the trigger section - hide buttons
            isPastTrigger = false;
            floatingSideButtons.style.opacity = '0';
            floatingSideButtons.style.pointerEvents = 'none';
          }
        });
      }, {
        threshold: [0, 0.1, 1],
        rootMargin: '0px'
      });
      
      // Observer for footer
      if (footer) {
        const footerObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting && isPastTrigger) {
              // Footer is visible - hide buttons
              floatingSideButtons.style.opacity = '0';
              floatingSideButtons.style.pointerEvents = 'none';
            } else if (!entry.isIntersecting && isPastTrigger) {
              // Footer is not visible and we're past trigger - show buttons
              floatingSideButtons.style.opacity = '1';
              floatingSideButtons.style.pointerEvents = 'auto';
            }
          });
        }, {
          threshold: 0.1,
          rootMargin: '0px'
        });
        
        footerObserver.observe(footer);
      }
      
      triggerObserver.observe(targetSection);
    });
  </script>
)}
