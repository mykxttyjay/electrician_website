---
const features = [
  {
    title: 'Licensed & Insured Electricians',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z'
  },
  {
    title: 'Expert Electrical Services',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z'
  },
  {
    title: 'Affordable & 24/7 Available',
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'
  }
];
---

<section class="bg-[#F5F5F5] py-16 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {features.map((feature, index) => (
        <div class="group flex items-stretch bg-white overflow-hidden feature-card shadow-xl hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 border-l-4 border-[#F4C430] hover:border-l-8" data-index={index}>
          <!-- Yellow Section with Icon -->
          <div class="bg-gradient-to-br from-[#F4C430] to-[#e5b52a] w-36 flex items-center justify-center flex-shrink-0 relative overflow-hidden">
            <!-- Animated background effect -->
            <div class="absolute inset-0 bg-white opacity-0 group-hover:opacity-10 transition-opacity duration-500"></div>
            <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center shadow-lg group-hover:scale-110 group-hover:rotate-12 transition-all duration-500 relative z-10">
              <svg class="w-10 h-10 text-[#F4C430] group-hover:text-[#e5b52a] transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon}></path>
              </svg>
            </div>
            <!-- Pulse effect -->
            <div class="absolute inset-0 rounded-full border-2 border-white opacity-0 group-hover:opacity-30 group-hover:scale-150 transition-all duration-700"></div>
          </div>
          
          <!-- Black Section with Text -->
          <div class="bg-gradient-to-r from-black to-[#1a1a1a] flex-1 flex flex-col justify-center px-6 py-8 relative overflow-hidden">
            <!-- Animated shine effect -->
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-[#F4C430]/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
            <div class="relative z-10">
              <p class="text-[#F4C430] text-xs font-bold mb-2 tracking-widest uppercase group-hover:tracking-[0.2em] transition-all duration-300">Why Choose Us</p>
              <h3 class="text-white text-lg font-black leading-tight group-hover:text-[#F4C430] transition-colors duration-300">{feature.title}</h3>
            </div>
            <!-- Corner accent -->
            <div class="absolute bottom-0 right-0 w-16 h-16 bg-[#F4C430] opacity-5 transform rotate-45 translate-x-8 translate-y-8 group-hover:scale-150 transition-transform duration-500"></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-card {
    opacity: 0;
    transform: translateY(30px);
  }

  .feature-card.animate {
    animation: fadeInUp 0.8s ease-out forwards;
  }

  .feature-card[data-index="0"].animate {
    animation-delay: 0.1s;
  }

  .feature-card[data-index="1"].animate {
    animation-delay: 0.2s;
  }

  .feature-card[data-index="2"].animate {
    animation-delay: 0.3s;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  // Intersection Observer for scroll animations
  const featuresObserverOptions = {
    threshold: 0.2,
    rootMargin: '0px 0px -50px 0px'
  };

  const featuresObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate');
        featuresObserver.unobserve(entry.target);
      }
    });
  }, featuresObserverOptions);

  // Observe feature cards
  const featureCards = document.querySelectorAll('.feature-card');
  featureCards.forEach(card => featuresObserver.observe(card));
</script>
