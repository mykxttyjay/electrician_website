<style>
  .maintenance-header {
    opacity: 0;
    animation: fadeInUp 0.8s ease-out forwards;
  }

  .maintenance-card {
    opacity: 0;
    transform: translateY(30px);
  }

  .maintenance-card.animate {
    animation: fadeInUp 0.8s ease-out forwards;
  }

  .maintenance-card:nth-child(1).animate {
    animation-delay: 0.2s;
  }

  .maintenance-card:nth-child(2).animate {
    animation-delay: 0.4s;
  }

  .maintenance-card:nth-child(3).animate {
    animation-delay: 0.6s;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  const maintenanceObserverOptions = {
    threshold: 0.2,
    rootMargin: '0px 0px -50px 0px'
  };

  const maintenanceObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate');
        maintenanceObserver.unobserve(entry.target);
      }
    });
  }, maintenanceObserverOptions);

  document.querySelectorAll('.maintenance-card').forEach(card => {
    maintenanceObserver.observe(card);
  });
</script>
