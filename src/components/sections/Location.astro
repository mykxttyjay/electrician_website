---
// Location component for electrician website
---

<section class="bg-white py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="mb-8">
      <p class="text-[#F4C430] font-semibold mb-2 uppercase" style="font-size: 18px;">Our Location</p>
      <h2 class="heading-h2 font-bold text-black mb-4">Service Areas in Los Angeles</h2>
    </div>

    <!-- Location Tabs -->
    <div class="mb-8 flex flex-wrap gap-4">
      <button class="location-tab active px-6 py-3 bg-white border-2 border-gray-300 text-black font-semibold transition-all hover:border-[#F4C430] hover:bg-[#F4C430] flex items-center gap-2" data-location="santa-monica">
        <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        Santa Monica
      </button>
      <button class="location-tab px-6 py-3 bg-white border-2 border-gray-300 text-gray-700 font-semibold transition-all hover:bg-[#F4C430] hover:border-[#F4C430] flex items-center gap-2" data-location="pasadena">
        <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        Pasadena
      </button>
      <button class="location-tab px-6 py-3 bg-white border-2 border-gray-300 text-gray-700 font-semibold transition-all hover:bg-[#F4C430] hover:border-[#F4C430] flex items-center gap-2" data-location="glendale">
        <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        Glendale
      </button>
      <button class="location-tab px-6 py-3 bg-white border-2 border-gray-300 text-gray-700 font-semibold transition-all hover:bg-[#F4C430] hover:border-[#F4C430] flex items-center gap-2" data-location="hollywood">
        <svg class="w-5 h-5 text-gray-400" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        Beverly Hills
      </button>
    </div>

    <!-- Description -->
    <div class="mb-8">
      <p class="text-gray-700 leading-relaxed max-w-5xl" style="font-size: 22px;">
        Expert residential and commercial electrical solutions across Los Angeles. We offer routine maintenance and 24/7 emergency services, committed to quality and customer satisfaction.
      </p>
    </div>

    <!-- Map Container -->
    <div class="relative bg-gray-200 rounded-lg overflow-hidden" style="height: 400px;">
      <div class="absolute top-4 left-4 bg-white px-4 py-2 rounded shadow-md z-10">
        <a href="https://maps.google.com" target="_blank" class="text-[#F4C430] font-semibold flex items-center gap-2 hover:text-black transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
          Open in Maps
        </a>
      </div>
      
      <!-- Placeholder Map - Replace with actual map integration -->
      <iframe 
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d423286.27404345275!2d-118.69192993092697!3d34.02016130653294!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80c2c75ddc27da13%3A0xe22fdf6f254608f4!2sLos%20Angeles%2C%20CA!5e0!3m2!1sen!2sus!4v1234567890123!5m2!1sen!2sus"
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll('.location-tab');
  
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      // Remove active state from all tabs
      tabs.forEach(t => {
        t.classList.remove('active', 'border-[#F4C430]', 'bg-[#F4C430]');
        t.classList.add('border-gray-300', 'text-gray-700');
        const icon = t.querySelector('svg');
        if (icon) {
          icon.classList.remove('text-[#F4C430]');
          icon.classList.add('text-gray-400');
        }
      });
      
      // Add active state to clicked tab
      tab.classList.add('active', 'border-[#F4C430]');
      tab.classList.remove('border-gray-300');
      const icon = tab.querySelector('svg');
      if (icon) {
        icon.classList.add('text-[#F4C430]');
        icon.classList.remove('text-gray-400');
      }
      
      // Here you can add logic to update the map based on the selected location
      const location = tab.getAttribute('data-location');
      console.log('Selected location:', location);
    });
  });
</script>

<style>
  .location-tab.active {
    background-color: white;
  }
</style>
