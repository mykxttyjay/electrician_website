---
---

<div id="floating-offer" class="fixed bottom-8 right-8 z-50 transition-all duration-300">
  <button 
    id="floating-offer-btn"
    class="flex items-center gap-2 bg-[#F4C430] text-black px-4 py-3 shadow-2xl hover:shadow-3xl transition-all duration-300 hover:scale-105 hover:bg-[#e5b52a] animate-[floatingPulse_2s_ease-in-out_infinite] hover:animate-none"
  >
    <div class="w-10 h-10 bg-black rounded-full flex items-center justify-center flex-shrink-0">
      <svg class="w-5 h-5 text-[#F4C430]" fill="currentColor" viewBox="0 0 24 24">
        <path d="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z"/>
      </svg>
    </div>
    <div class="text-left pr-2">
      <p class="text-black font-bold text-xs uppercase tracking-wide">Special Offer</p>
      <p class="text-black font-bold text-base">Claim Now</p>
    </div>
  </button>
</div>

<script>
  const floatingBtn = document.getElementById('floating-offer-btn');
  const modal = document.getElementById('offer-modal');
  
  floatingBtn?.addEventListener('click', () => {
    if (modal) {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }
  });
</script>
