---
// Why Choose Us component for electrician website
import Button from '../ui/Button.astro';
---

<section class="bg-white py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
      <!-- Left Side: Image -->
      <div class="relative">
        <img 
          src="https://images.unsplash.com/photo-1621905251918-48416bd8575a?w=800&h=600&fit=crop&q=80" 
          alt="Professional Electrician" 
          class="w-full h-[500px] object-cover rounded-lg"
        />
      </div>

      <!-- Right Side: Content -->
      <div>
        <p class="text-[#F4C430] font-semibold mb-4" style="font-size: 18px;">Why Choose Us</p>
        
        <h2 class="heading-h2 font-bold text-black mb-6" style="line-height: 1.2;">
          Professional Service You Can Count On
        </h2>
        
        <p class="text-gray-700 leading-relaxed mb-8" style="font-size: 22px;">
          With decades of experience and commitment to excellence, we deliver electrical solutions that prioritize safety, reliability, and customer satisfaction.
        </p>

        <!-- Checkmarks -->
        <div class="space-y-4 mb-8">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 text-[#F4C430] flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 24 24">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
            </svg>
            <p class="text-gray-700" style="font-size: 16px;">Powered by years of industry experience and excellence.</p>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 text-[#F4C430] flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 24 24">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
            </svg>
            <p class="text-gray-700" style="font-size: 16px;">Dedicated to providing safe and efficient electrical services.</p>
          </div>
        </div>

        <!-- Buttons -->
        <div class="flex flex-wrap items-center gap-6">
          <Button variant="accent" size="md" href="/contact" icon={true}>
            Contact Us
          </Button>
          
          <a href="tel:+12345678912" class="flex items-center gap-3 group">
            <div class="w-12 h-12 bg-[#F4C430] rounded-full flex items-center justify-center group-hover:bg-[#e5b52a] transition-colors">
              <svg class="w-6 h-6 text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
              </svg>
            </div>
            <div>
              <p class="text-black font-semibold text-sm">Call Us Now</p>
              <p class="text-black font-bold text-lg">+(234) 567 8912</p>
            </div>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Card 1: Reliable Electrical Solutions -->
      <div class="bg-[#FFF9E6] rounded-lg p-6 flex gap-4">
        <div class="flex-shrink-0">
          <svg class="w-12 h-12 text-[#F4C430]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-xl font-bold text-black mb-2">Reliable Electrical Solutions</h3>
          <p class="text-gray-700" style="font-size: 14px;">
            Trusted electrical services backed by certified professionals and proven track record.
          </p>
        </div>
      </div>

      <!-- Card 2: Dedicated to Quality -->
      <div class="bg-[#FFF9E6] rounded-lg p-6 flex gap-4">
        <div class="flex-shrink-0">
          <svg class="w-12 h-12 text-[#F4C430]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-xl font-bold text-black mb-2">Dedicated to Quality</h3>
          <p class="text-gray-700" style="font-size: 14px;">
            Every project meets highest standards with meticulous attention to detail and safety.
          </p>
        </div>
      </div>

      <!-- Card 3: Partnering for Your Success -->
      <div class="bg-[#FFF9E6] rounded-lg p-6 flex gap-4">
        <div class="flex-shrink-0">
          <svg class="w-12 h-12 text-[#F4C430]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-xl font-bold text-black mb-2">Partnering for Your Success</h3>
          <p class="text-gray-700" style="font-size: 14px;">
            Building lasting relationships through exceptional service and reliable support.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
