---

<section class="bg-[#F8F8F8] py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="mb-12 text-center services-header">
      <p class="text-[#e5b52a] font-semibold mb-2 text-lg flex items-center justify-center gap-2">
        <svg class="w-5 h-5 text-[#F4C430]" fill="currentColor" viewBox="0 0 24 24">
          <path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z"/>
        </svg>
        Our Services
      </p>
      <h2 class="heading-h2 font-bold text-black mb-4 mx-auto" style="line-height: 1.2;">Comprehensive Electrical Services</h2>
      <p class="text-gray-700 leading-relaxed max-w-5xl mx-auto text-subtitle">
        From residential installations to commercial projects, we provide complete electrical services tailored to your specific needs with guaranteed quality and safety.
      </p>
    </div>

    <!-- Service Category Tabs -->
    <div class="flex flex-wrap gap-6 mb-10 justify-center services-tabs">
      {serviceCategories.map((category, index) => (
        <button
          class={`service-tab group relative px-10 py-5 rounded-lg transition-all duration-300 shadow-md hover:shadow-xl ${index === 0 ? 'active bg-gradient-to-r from-[#F4C430] to-[#e5b52a] text-black' : 'bg-white text-gray-700 border-2 border-gray-200'} hover:bg-gradient-to-r hover:from-[#F4C430] hover:to-[#e5b52a] hover:text-black hover:border-transparent hover:-translate-y-1`}
          data-category={category.id}
          data-index={index}
        >
          <span class="font-bold text-lg whitespace-nowrap relative z-10">{category.title}</span>
          {index === 0 && (
            <div class="absolute left-1/2 -translate-x-1/2 -bottom-3 w-0 h-0 border-l-[14px] border-l-transparent border-r-[14px] border-r-transparent border-t-[14px] border-t-[#e5b52a] drop-shadow-md"></div>
          )}
        </button>
      ))}
    </div>

    <!-- Services Grid (Dynamic Content) -->
    {serviceCategories.map((category, catIndex) => (
      <div 
        class={`service-content ${catIndex === 0 ? '' : 'hidden'}`}
        data-category={category.id}
      >
        <!-- Top: Description (Centered) -->
        <div class="text-center mb-10">
          <h3 class="text-3xl font-bold text-black mb-6">{category.title}</h3>
          <p class="text-gray-700 text-base leading-relaxed max-w-5xl mx-auto">{category.description}</p>
        </div>

        <!-- Bottom: 4 Services in 1 Row -->
        <div class="grid grid-cols-4 gap-6 services-grid">
          {category.services.map((service, serviceIndex) => (
            <div data-service-index={serviceIndex}>
              <ServiceCard name={service.name} image={service.image} description={service.description} icon={service.icon} />
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .services-header {
    opacity: 0;
    animation: fadeInUp 0.8s ease-out forwards;
  }

  .services-tabs {
    opacity: 0;
    animation: fadeInUp 0.8s ease-out 0.2s forwards;
  }

  .service-tab {
    opacity: 0;
    transform: translateY(20px);
  }

  .services-tabs.animate .service-tab {
    animation: fadeInUp 0.6s ease-out forwards;
  }

  .service-tab[data-index="0"] {
    animation-delay: 0.3s;
  }

  .service-tab[data-index="1"] {
    animation-delay: 0.4s;
  }

  .service-tab[data-index="2"] {
    animation-delay: 0.5s;
  }

  .service-tab[data-index="3"] {
    animation-delay: 0.6s;
  }

  .services-grid > div {
    opacity: 0;
    transform: translateY(30px);
  }

  .services-grid.animate > div {
    animation: fadeInUp 0.8s ease-out forwards;
  }

  .services-grid.animate > div[data-service-index="0"] {
    animation-delay: 0.1s;
  }

  .services-grid.animate > div[data-service-index="1"] {
    animation-delay: 0.2s;
  }

  .services-grid.animate > div[data-service-index="2"] {
    animation-delay: 0.3s;
  }

  .services-grid.animate > div[data-service-index="3"] {
    animation-delay: 0.4s;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  // Intersection Observer for scroll animations
  const servicesObserverOptions = {
    threshold: 0.2,
    rootMargin: '0px 0px -50px 0px'
  };

  const servicesObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate');
        servicesObserver.unobserve(entry.target);
      }
    });
  }, servicesObserverOptions);

  // Observe services elements
  const servicesTabs = document.querySelector('.services-tabs');
  const servicesGrids = document.querySelectorAll('.services-grid');
  
  if (servicesTabs) servicesObserver.observe(servicesTabs);
  servicesGrids.forEach(grid => servicesObserver.observe(grid));

  // Tab functionality
  const tabs = document.querySelectorAll('.service-tab');
  const contents = document.querySelectorAll('.service-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const categoryId = tab.getAttribute('data-category');

      // Remove active state from all tabs
      tabs.forEach(t => {
        t.classList.remove('active', 'bg-gradient-to-r', 'from-[#F4C430]', 'to-[#e5b52a]', 'text-black', 'border-transparent');
        t.classList.add('bg-white', 'text-gray-700', 'border-2', 'border-gray-200');
        
        // Remove pointer
        const pointer = t.querySelector('.absolute.left-1\\/2');
        if (pointer && pointer.classList.contains('border-t-[14px]')) pointer.remove();
      });

      // Add active state to clicked tab
      tab.classList.add('active', 'bg-gradient-to-r', 'from-[#F4C430]', 'to-[#e5b52a]', 'text-black', 'border-transparent');
      tab.classList.remove('bg-white', 'text-gray-700', 'border-2', 'border-gray-200');
      
      // Add pointer
      const pointer = document.createElement('div');
      pointer.className = 'absolute left-1/2 -translate-x-1/2 -bottom-3 w-0 h-0 border-l-[14px] border-l-transparent border-r-[14px] border-r-transparent border-t-[14px] border-t-[#e5b52a] drop-shadow-md';
      tab.appendChild(pointer);

      // Hide all content
      contents.forEach(content => content.classList.add('hidden'));

      // Show selected content
      const selectedContent = document.querySelector(`.service-content[data-category="${categoryId}"]`);
      if (selectedContent) {
        selectedContent.classList.remove('hidden');
        
        // Re-trigger animation for the newly visible grid
        const newGrid = selectedContent.querySelector('.services-grid');
        if (newGrid) {
          newGrid.classList.remove('animate');
          // Use requestAnimationFrame to batch DOM operations
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              newGrid.classList.add('animate');
            });
          });
        }
      }
    });
  });
</script>
