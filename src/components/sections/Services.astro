      { name: 'Water Heater', image: 'https://images.unsplash.com/photo-1620653713380-7a34b773fef8?q=80&w=945&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D', description: 'Professional water heater electrical installation and repair services.', icon: 'data:image/svg+xml,%3Csvg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="black" stroke-width="2"%3E%3Cpath stroke-linecap="round" stroke-linejoin="round" d="M3 12h3m6-9v3m6 6h3M6 6l2 2m10 10l2 2M7 20h10a2 2 0 002-2V6a2 2 0 00-2-2H7a2 2 0 00-2 2v12a2 2 0 002 2zm3-8a2 2 0 104 0 2 2 0 00-4 0z"/%3E%3C/svg%3E' }
