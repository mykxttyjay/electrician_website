---

<section class="bg-[#F8F8F8] py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="mb-12 text-center">
      <p class="text-[#F4C430] font-semibold mb-2 text-lg">Our Services</p>
      <h2 class="heading-h2 font-bold text-black mb-4 mx-auto" style="line-height: 1.2;">Comprehensive Electrical Services</h2>
      <p class="text-gray-700 leading-relaxed max-w-5xl mx-auto text-subtitle">
        From residential installations to commercial projects, we provide complete electrical services tailored to your specific needs with guaranteed quality and safety.
      </p>
    </div>

    <!-- Service Category Tabs -->
    <div class="flex flex-wrap gap-4 mb-10 justify-center">
      {serviceCategories.map((category, index) => (
        <button
          class={`service-tab relative px-8 py-4 transition-all ${index === 0 ? 'active bg-[#F4C430] text-black' : 'bg-white text-gray-700'} hover:bg-[#F4C430] hover:text-black`}
          data-category={category.id}
        >
          <div class="flex flex-col items-center gap-2">
            <svg class={`w-10 h-10 ${index === 0 ? 'text-black' : 'text-gray-400'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={category.icon}></path>
            </svg>
            <span class="font-bold text-base whitespace-nowrap">{category.title}</span>
          </div>
          {index === 0 && (
            <div class="absolute left-1/2 -translate-x-1/2 -bottom-3 w-0 h-0 border-l-[12px] border-l-transparent border-r-[12px] border-r-transparent border-t-[12px] border-t-[#F4C430]"></div>
          )}
        </button>
      ))}
    </div>

    <!-- Services Grid (Dynamic Content) -->
    {serviceCategories.map((category, catIndex) => (
      <div 
        class={`service-content ${catIndex === 0 ? '' : 'hidden'}`}
        data-category={category.id}
      >
        <!-- Top: Description (Centered) -->
        <div class="text-center mb-10">
          <h3 class="text-3xl font-bold text-black mb-6">{category.title}</h3>
          <p class="text-gray-700 text-base leading-relaxed max-w-4xl mx-auto">{category.description}</p>
        </div>

        <!-- Bottom: 4 Services in 1 Row -->
        <div class="grid grid-cols-4 gap-6">
          {category.services.map((service) => (
            <div class="group cursor-pointer relative overflow-hidden">
              <div class="w-full aspect-square overflow-hidden bg-gray-200">
                <img 
                  src={service.image} 
                  alt={service.name}
                  class="w-full h-full object-cover"
                />
              </div>
              <!-- Hover Overlay -->
              <div class="absolute inset-0 bg-gradient-to-r from-[#F4C430]/80 to-[#F4C430]/60 translate-x-[-100%] group-hover:translate-x-0 transition-transform duration-500 ease-in-out flex items-end justify-center pb-6">
                <h4 class="text-base font-bold text-black text-center px-4 whitespace-nowrap overflow-hidden text-ellipsis w-full">{service.name}</h4>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const tabs = document.querySelectorAll('.service-tab');
  const contents = document.querySelectorAll('.service-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const categoryId = tab.getAttribute('data-category');

      // Remove active state from all tabs
      tabs.forEach(t => {
        t.classList.remove('active', 'bg-[#F4C430]', 'text-black');
        t.classList.add('bg-white', 'text-gray-700');
        const icon = t.querySelector('svg');
        if (icon) icon.classList.replace('text-black', 'text-gray-400');
        
        // Remove pointer
        const pointer = t.querySelector('.absolute');
        if (pointer) pointer.remove();
      });

      // Add active state to clicked tab
      tab.classList.add('active', 'bg-[#F4C430]', 'text-black');
      tab.classList.remove('bg-white', 'text-gray-700');
      const icon = tab.querySelector('svg');
      if (icon) icon.classList.replace('text-gray-400', 'text-black');
      
      // Add pointer
      const pointer = document.createElement('div');
      pointer.className = 'absolute left-1/2 -translate-x-1/2 -bottom-3 w-0 h-0 border-l-[12px] border-l-transparent border-r-[12px] border-r-transparent border-t-[12px] border-t-[#F4C430]';
      tab.appendChild(pointer);

      // Hide all content
      contents.forEach(content => content.classList.add('hidden'));

      // Show selected content
      const selectedContent = document.querySelector(`.service-content[data-category="${categoryId}"]`);
      if (selectedContent) selectedContent.classList.remove('hidden');
    });
  });
</script>
