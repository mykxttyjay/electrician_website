---
import Button from '../ui/Button.astro';
---

<section class="bg-[#F8F8F8] py-20 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
  <div class="max-w-7xl mx-auto relative z-10">
    <!-- Section Header -->
    <div class="mb-12 text-center financing-header">
      <div class="flex items-center justify-center gap-2">
        <svg class="w-5 h-5 text-[#F4C430]" fill="currentColor" viewBox="0 0 24 24">
          <path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z"/>
        </svg>
        <p class="text-[#F4C430] font-semibold text-lg">Financing Options</p>
      </div>
      <h2 class="heading-h2 font-bold text-black mb-4">Flexible Payment Solutions</h2>
      <p class="text-gray-700 leading-relaxed max-w-3xl mx-auto text-subtitle">
        Don't let budget constraints hold you back. We offer flexible financing options to make your electrical projects affordable.
      </p>
    </div>

    <!-- Financing Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Left: Benefits -->
      <div class="financing-benefits">
        <h3 class="text-2xl font-bold text-black mb-6">Why Choose Our Financing?</h3>
        <div class="space-y-4">
          <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-[#F4C430] hover:shadow-xl transition-all duration-300 hover:-translate-y-1 flex items-start gap-4">
            <div class="w-16 h-16 bg-[#F4C430] flex items-center justify-center flex-shrink-0">
              <svg class="w-8 h-8 text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-xl font-bold text-black mb-2">Quick Approval</h4>
              <p class="text-gray-700">Get approved in minutes with our streamlined application</p>
            </div>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-[#F4C430] hover:shadow-xl transition-all duration-300 hover:-translate-y-1 flex items-start gap-4">
            <div class="w-16 h-16 bg-[#F4C430] flex items-center justify-center flex-shrink-0">
              <svg class="w-8 h-8 text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-xl font-bold text-black mb-2">Low Monthly Payments</h4>
              <p class="text-gray-700">Affordable payment plans that fit your budget</p>
            </div>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-[#F4C430] hover:shadow-xl transition-all duration-300 hover:-translate-y-1 flex items-start gap-4">
            <div class="w-16 h-16 bg-[#F4C430] flex items-center justify-center flex-shrink-0">
              <svg class="w-8 h-8 text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-xl font-bold text-black mb-2">Flexible Terms</h4>
              <p class="text-gray-700">Choose from 6, 12, 24, or 36-month payment plans</p>
            </div>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-md border-l-4 border-[#F4C430] hover:shadow-xl transition-all duration-300 hover:-translate-y-1 flex items-start gap-4">
            <div class="w-16 h-16 bg-[#F4C430] flex items-center justify-center flex-shrink-0">
              <svg class="w-8 h-8 text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-xl font-bold text-black mb-2">No Hidden Fees</h4>
              <p class="text-gray-700">Transparent pricing with no surprise charges</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Image -->
      <div class="financing-options">
        <div class="rounded-lg overflow-hidden shadow-lg h-full">
          <img 
            src="https://images.unsplash.com/photo-1660330589827-da8ab7dd3c02?q=60&w=800&auto=format&fit=crop" 
            alt="Financing Options" 
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .financing-header {
    opacity: 0;
    animation: fadeInUp 0.8s ease-out forwards;
  }

  .financing-benefits {
    opacity: 0;
    transform: translateX(-30px);
  }

  .financing-benefits.animate {
    animation: slideInLeft 0.8s ease-out 0.3s forwards;
  }

  .financing-options {
    opacity: 0;
    transform: translateX(30px);
  }

  .financing-options.animate {
    animation: slideInRight 0.8s ease-out 0.3s forwards;
  }

  .financing-cta {
    opacity: 0;
    transform: translateY(20px);
  }

  .financing-cta.animate {
    animation: fadeInUp 0.8s ease-out 0.6s forwards;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideInLeft {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes slideInRight {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
</style>

<script>
  const financingObserverOptions = {
    threshold: 0.2,
    rootMargin: '0px 0px -50px 0px'
  };

  const financingObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate');
        financingObserver.unobserve(entry.target);
      }
    });
  }, financingObserverOptions);

  const financingBenefits = document.querySelector('.financing-benefits');
  const financingOptions = document.querySelector('.financing-options');
  const financingCta = document.querySelector('.financing-cta');
  
  if (financingBenefits) financingObserver.observe(financingBenefits);
  if (financingOptions) financingObserver.observe(financingOptions);
  if (financingCta) financingObserver.observe(financingCta);
</script>
