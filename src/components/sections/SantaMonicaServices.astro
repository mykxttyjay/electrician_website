---
// Santa Monica Services Highlight Section
---

<section class="relative bg-[#F8F8F8] py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <p class="text-[#F4C430] font-semibold text-lg flex items-center justify-center gap-2 mb-3">
        <svg class="w-5 h-5 text-[#F4C430]" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2L3 14h8l-1 8 10-12h-8l1-8z"/>
        </svg>
        Santa Monica's Trusted Electricians
      </p>
      <h2 class="heading-h2 font-bold text-black mb-4">
        Why Choose Us in Santa Monica
      </h2>
      <p class="text-gray-700 leading-relaxed max-w-5xl mx-auto text-subtitle">
        From beachfront properties to downtown businesses, we provide fast, reliable electrical solutions tailored to Santa Monica's unique needs. Available 24/7.
      </p>
    </div>

    <!-- Services List with Center Image -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-16">
      <!-- Left Column -->
      <div class="space-y-8">
        <!-- Service 1 -->
        <div class="flex gap-4">
          <span class="text-[#F4C430] text-4xl font-bold">01.</span>
          <div>
            <h3 class="text-xl font-bold text-black mb-2">Electrical repairs</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Our electronic services include installation, maintenance, and repair of all types of electrical systems for residential and commercial buildings.
            </p>
          </div>
        </div>

        <!-- Service 2 -->
        <div class="flex gap-4">
          <span class="text-[#F4C430] text-4xl font-bold">02.</span>
          <div>
            <h3 class="text-xl font-bold text-black mb-2">Safety improvement</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Looking for energy-efficient lighting solutions? Our experts can help you choose the right LED lighting systems that meet your needs and budget.
            </p>
          </div>
        </div>

        <!-- Service 3 -->
        <div class="flex gap-4">
          <span class="text-[#F4C430] text-4xl font-bold">03.</span>
          <div>
            <h3 class="text-xl font-bold text-black mb-2">Emergency service</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Available 24/7 for urgent electrical issues. Fast response times to keep your property safe and operational at all times.
            </p>
          </div>
        </div>
      </div>

      <!-- Center Image -->
      <div class="flex items-center justify-center">
        <img 
          src="https://images.unsplash.com/photo-1621905251918-48416bd8575a?q=80&w=687&auto=format&fit=crop" 
          alt="Electrical Services" 
          class="w-full max-w-sm h-auto object-contain"
        />
      </div>

      <!-- Right Column -->
      <div class="space-y-8">
        <!-- Service 4 -->
        <div class="flex gap-4">
          <div class="text-right flex-1">
            <h3 class="text-xl font-bold text-black mb-2">Surge protection</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Our experienced technicians can perform electrical safety inspections to identify potential hazards and ensure that your electrical systems are up to code.
            </p>
          </div>
          <span class="text-[#F4C430] text-4xl font-bold">04.</span>
        </div>

        <!-- Service 5 -->
        <div class="flex gap-4">
          <div class="text-right flex-1">
            <h3 class="text-xl font-bold text-black mb-2">Panel upgrades</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Upgrade your electrical panel to improve energy efficiency, increase capacity, and protect your home or business from power surges and electrical fires.
            </p>
          </div>
          <span class="text-[#F4C430] text-4xl font-bold">05.</span>
        </div>

        <!-- Service 6 -->
        <div class="flex gap-4">
          <div class="text-right flex-1">
            <h3 class="text-xl font-bold text-black mb-2">Smart home integration</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Modern smart home electrical solutions for automated lighting, climate control, and security systems tailored to your lifestyle.
            </p>
          </div>
          <span class="text-[#F4C430] text-4xl font-bold">06.</span>
        </div>
      </div>
    </div>

    <!-- Why Choose Us Benefits Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <!-- Benefit 1 -->
      <div class="bg-white rounded-xl p-6 text-center shadow-md hover:shadow-lg transition-shadow duration-300">
        <div class="w-16 h-16 bg-[#F4C430] rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <h4 class="font-bold text-black mb-2">Fast Response</h4>
        <p class="text-gray-600 text-sm">
          We're always nearby and ready to help with quick arrival times.
        </p>
      </div>

      <!-- Benefit 2 -->
      <div class="bg-white rounded-xl p-6 text-center shadow-md hover:shadow-lg transition-shadow duration-300">
        <div class="w-16 h-16 bg-[#F4C430] rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h4 class="font-bold text-black mb-2">Licensed & Insured</h4>
        <p class="text-gray-600 text-sm">
          Fully licensed California electricians with comprehensive insurance coverage.
        </p>
      </div>

      <!-- Benefit 3 -->
      <div class="bg-white rounded-xl p-6 text-center shadow-md hover:shadow-lg transition-shadow duration-300">
        <div class="w-16 h-16 bg-[#F4C430] rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h4 class="font-bold text-black mb-2">Upfront Pricing</h4>
        <p class="text-gray-600 text-sm">
          Clear, honest pricing with no hidden fees or surprise charges.
        </p>
      </div>

      <!-- Benefit 4 -->
      <div class="bg-white rounded-xl p-6 text-center shadow-md hover:shadow-lg transition-shadow duration-300">
        <div class="w-16 h-16 bg-[#F4C430] rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5"/>
          </svg>
        </div>
        <h4 class="font-bold text-black mb-2">Quality Guarantee</h4>
        <p class="text-gray-600 text-sm">
          100% satisfaction guarantee on all our electrical work and services.
        </p>
      </div>
    </div>

    <!-- Statistics Banner -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Stat 1 -->
      <div class="bg-gradient-to-r from-black to-gray-900 rounded-2xl p-8 text-center">
        <h3 class="text-white text-xl font-semibold mb-4">Quick Service</h3>
        <div class="w-full h-px bg-gray-600 mb-6"></div>
        <div class="text-[#F4C430] text-5xl font-bold mb-3">15 Min</div>
        <p class="text-gray-300 text-base">Average Response Time</p>
      </div>

      <!-- Stat 2 -->
      <div class="bg-gradient-to-r from-black to-gray-900 rounded-2xl p-8 text-center">
        <h3 class="text-white text-xl font-semibold mb-4">Digital Excellence</h3>
        <div class="w-full h-px bg-gray-600 mb-6"></div>
        <div class="text-[#F4C430] text-5xl font-bold mb-3">500+</div>
        <p class="text-gray-300 text-base">Projects Completed</p>
      </div>

      <!-- Stat 3 -->
      <div class="bg-gradient-to-r from-black to-gray-900 rounded-2xl p-8 text-center">
        <h3 class="text-white text-xl font-semibold mb-4">Professional Team</h3>
        <div class="w-full h-px bg-gray-600 mb-6"></div>
        <div class="text-[#F4C430] text-5xl font-bold mb-3">100%</div>
        <p class="text-gray-300 text-base">Licensed & Insured</p>
      </div>
    </div>
  </div>
</section>

<script>
  // Intersection Observer for scroll animations
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('opacity-100', 'translate-y-0');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  // Observe benefit cards
  document.querySelectorAll('.shadow-md').forEach(card => {
    card.classList.add('opacity-0', 'translate-y-8', 'transition-all', 'duration-700');
    observer.observe(card);
  });
</script>
