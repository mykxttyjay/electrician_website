---
import Layout from '../layouts/Layout.astro';
import Header from '../components/sections/Header.astro';
import Hero2 from '../components/sections/Hero2.astro';
import AboutSantaMonica from '../components/sections/AboutSantaMonica.astro';
import Services from '../components/sections/Services.astro';
import Coupons from '../components/sections/Coupons.astro';
import Portfolio from '../components/sections/Portfolio.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import CallToAction from '../components/sections/CallToAction.astro';
import Footer from '../components/sections/Footer.astro';
import FloatingOffer from '../components/sections/FloatingOffer.astro';
import FloatingSideButtons from '../components/sections/FloatingSideButtons.astro';
import OfferModal from '../components/sections/OfferModal.astro';
---

<Layout 
  title="Santa Monica Services" 
>
  <Header />
  
  <Hero2 
    backgroundImage="https://images.unsplash.com/photo-1523430410476-0185cb1f6ff9?q=80&w=1074&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
    title="Santa Monica"
  />

  <AboutSantaMonica />
  <Coupons />
  <Services />
  <Portfolio />
  <Testimonials />
  <CallToAction />

  <!-- Enhanced Map Section -->
  <section class="bg-[#F8F8F8] py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-10">
        <h2 class="heading-h2 font-bold text-black mb-2">Find Us in Santa Monica</h2>
        <p class="text-gray-700 leading-relaxed max-w-4xl mx-auto text-subtitle">
          Conveniently located to serve all of Santa Monica and surrounding areas
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Contact Info Cards -->
        <div class="lg:col-span-1 space-y-6">
          <!-- Address Card -->
          <div class="bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 border-l-4 border-[#F4C430]">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-[#F4C430] rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-black" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-black mb-2">Our Location</h3>
                <p class="text-gray-700">Santa Monica, CA</p>
                <p class="text-gray-600 text-sm mt-2">Serving all neighborhoods</p>
              </div>
            </div>
          </div>

          <!-- Phone Card -->
          <div class="bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 border-l-4 border-[#F4C430]">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-[#F4C430] rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-black" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-black mb-2">Call Us</h3>
                <a href="tel:+12345678912" class="text-[#F4C430] font-bold text-xl hover:text-[#e5b52a] transition-colors">
                  (234) 567 8912
                </a>
                <p class="text-gray-600 text-sm mt-2">24/7 Emergency Service</p>
              </div>
            </div>
          </div>

          <!-- Hours Card -->
          <div class="bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 border-l-4 border-[#F4C430]">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-[#F4C430] rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-black" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-black mb-2">Business Hours</h3>
                <div class="text-gray-700 space-y-1">
                  <p class="text-sm"><span class="font-semibold">Mon-Fri:</span> 8AM - 6PM</p>
                  <p class="text-sm"><span class="font-semibold">Sat-Sun:</span> 9AM - 5PM</p>
                  <p class="text-[#F4C430] text-sm font-semibold mt-2">Emergency: 24/7</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Map -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-lg shadow-xl overflow-hidden h-full min-h-[500px]">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d211877.8952805003!2d-118.6919155!3d34.0194543!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80c2a4cec2910019%3A0xb4170ab5ff23f5ab!2sSanta%20Monica%2C%20CA!5e0!3m2!1sen!2sus!4v1234567890"
              width="100%" 
              height="100%" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy"
              class="w-full h-full"
              title="Google Maps showing Santa Monica location"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
  <FloatingOffer />
  <FloatingSideButtons showOnScroll={true} triggerSection="coupons" />
  <OfferModal />
</Layout>
