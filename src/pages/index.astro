---
import Header from '../components/sections/Header.astro';
import Home from '../components/sections/Home.astro';
import Coupons from '../components/sections/Coupons.astro';
import About from '../components/sections/About.astro';
import Services from '../components/sections/Services.astro';
import WhyChooseUs from '../components/sections/WhyChooseUs.astro';
import Stats from '../components/sections/Stats.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import FAQ from '../components/sections/FAQ.astro';
import Location from '../components/sections/Location.astro';
import CallToAction from '../components/sections/CallToAction.astro';
import Footer from '../components/sections/Footer.astro';
import FloatingOffer from '../components/sections/FloatingOffer.astro';
import OfferModal from '../components/sections/OfferModal.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<Header />
	<Home
		backgroundImage="https://images.unsplash.com/photo-1595831708961-1b13c0dd2422?q=80&w=1201&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
		subtitle="Brightening lives with reliable electrical solutions, one connection at a time"
		ctaText="EXPLORE NOW"
		ctaLink="/contact"
	/>
	<Coupons />
	<About />
	<Services />
	<Stats />
	<WhyChooseUs />
	<Testimonials />
	<FAQ />
	<Location />
	<CallToAction />
	<Footer />
	<FloatingOffer />
	<OfferModal />
</Layout>
