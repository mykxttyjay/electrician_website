---
import Layout from '../layouts/Layout.astro';
import Header from '../components/sections/Header.astro';
import Hero2 from '../components/sections/Hero2.astro';
import ServiceDetailSection from '../components/sections/ServiceDetailSection.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import FAQ from '../components/sections/FAQ.astro';
import Location from '../components/sections/Location.astro';
import CallToAction from '../components/sections/CallToAction.astro';
import Footer from '../components/sections/Footer.astro';
import FloatingOffer from '../components/sections/FloatingOffer.astro';
import FloatingSideButtons from '../components/sections/FloatingSideButtons.astro';
import OfferModal from '../components/sections/OfferModal.astro';
import WhyChooseUs from '../components/sections/WhyChooseUs.astro';
---

<Layout 
  title="Ground-Up Electrical Construction" 
>
  <Header />
  
  <Hero2 
    backgroundImage="https://images.unsplash.com/photo-1605313294941-ea43850d9de5?q=80&w=1140&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
    title="Ground-up Electrical Construction"
    titleSize="heading-h2"
  />

  <ServiceDetailSection 
    title="Ground-Up Electrical"
    description="Expert electrical construction services for new commercial and residential buildings. From initial planning to final inspection, we deliver comprehensive electrical systems that meet all code requirements."
    image="https://images.unsplash.com/photo-1660330589487-39cc0177ba89?q=80&w=1332&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
    imageAlt="Ground-up electrical construction"
    services={[
      { name: 'Ground-up Construction', link: '/ground-up-construction' },
      { name: 'Emergency & Standby Power', link: '/services/commercial/power-systems' },
      { name: 'Commercial HVAC Electrical', link: '/services/commercial/hvac' },
      { name: 'Electrical Panels', link: '/services/commercial/panels' }
    ]}
  />

  <WhyChooseUs />
  <Testimonials />
  <FAQ />
  <Location />
  <CallToAction />
  <Footer />
  <FloatingOffer />
  <FloatingSideButtons />
  <OfferModal />
</Layout>
